    "0dba6933-5ce7-4e22-8996-dae06492a99c": {
      "id": "0dba6933-5ce7-4e22-8996-dae06492a99c",
      "name": "Prologue",
      "type": "writing",
      "kind": "chapter",
      "content": "",
      "parentId": null,
      "order": 0,
      "outline": {
