    "a3c362ae-41d2-4960-bb77-940a620c9b0d": {
      "id": "a3c362ae-41d2-4960-bb77-940a620c9b0d",
      "name": "10 Storylines & Arcs",
      "type": "topic",
      "content": "<p><strong style=\"font-size:20px;\">Dragonblood Encyclopedia • Topic Frame</strong></p><p>\n</p><p><em>Template Card: 10 Storylines &amp; Arcs</em></p><p>\n</p><table style=\"border-collapse:collapse;table-layout:fixed;width:100%;border:2px solid #c8a24a;background:#1a1d22;\" data-clear-border=\"1\">\n  <tbody>\n    <tr>\n      <td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width: 23%; vertical-align: top; border: 1px solid rgb(109, 85, 48); background: rgb(34, 40, 49); padding: 10px;\" data-clear-border=\"1\">\n        <h3 style=\"margin:0 0 8px 0;color:#f0d78a;\">Linked Items</h3>\n        <p><strong>Topics</strong></p>\n        <ul>\n          <li>Primary Parent Topic</li>\n          <li>Supporting Subtopic</li>\n        </ul>\n        <p><strong>Characters</strong></p>\n        <ul>\n          <li>Lead Character</li>\n          <li>Supporting Character</li>\n        </ul>\n        <p><strong>Timeline</strong></p>\n        <ul>\n          <li>Anchor Event</li>\n        </ul>\n        <p><strong>Markers</strong></p>\n        <ul>\n          <li>Map Marker</li>\n        </ul>\n      </td>\n      <td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width: 54%; vertical-align: top; border: 1px solid rgb(109, 85, 48); background: rgb(31, 36, 43); padding: 12px;\" data-clear-border=\"1\" class=\"\">\n        <h1 style=\"margin-top:0;color:#f5e7b2;\">10 Storylines &amp; Arcs</h1>\n<ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-family: -apple-system, BlinkMacSystemFont, &quot;Segoe UI&quot;, Roboto, Oxygen, Ubuntu, Cantarell, &quot;Fira Sans&quot;, &quot;Droid Sans&quot;, &quot;Helvetica Neue&quot;, sans-serif; font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><strong style=\"box-sizing: border-box;\">The Holy War</strong></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><strong style=\"box-sizing: border-box;\">The Crystal War</strong></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><strong style=\"box-sizing: border-box;\">The Dragonborn Civil War</strong></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><strong style=\"box-sizing: border-box;\">The Redemption of Ravage</strong></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><strong style=\"box-sizing: border-box;\">Ardil’s Quest</strong></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><strong style=\"box-sizing: border-box;\">The Fall of the Gatebridges</strong></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><strong style=\"box-sizing: border-box;\">The Sherwin Restoration</strong></li></ul><ul>  </ul>\n      </td>\n      <td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width:23%;vertical-align:top;border:1px solid #6d5530;background:#222831;padding:10px;\" data-clear-border=\"1\">\n        <h3 style=\"margin:0 0 8px 0;color:#f0d78a;\">Related Elements</h3>\n        <p><strong>Character:</strong> One-line role summary.</p>\n        <p><strong>Event:</strong> One-line timeline impact.</p>\n        <p><strong>Map Zone:</strong> One-line location context.</p>\n        <p><strong>Template Note:</strong> Replace bullets with live links and concise references.</p>\n      </td>\n    </tr>\n  </tbod