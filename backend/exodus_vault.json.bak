  "topics": {
    "5a9894d8-3a68-41ca-9ce5-fac0d5a39144": {
      "id": "5a9894d8-3a68-41ca-9ce5-fac0d5a39144",
      "name": "overview",
      "type": "topic",
      "content": "<p><br></p><div class=\"ql-table-embed\"><table style=\"border-collapse: collapse; table-layout: fixed; width: 1106px; margin-left: auto; display: table; float: none; margin-right: auto;\" data-table-align=\"center\"><tbody><tr><td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"border: 1px solid rgb(228, 198, 47); background: transparent; padding: 4px; width: 100%; vertical-align: top;\" class=\"\"><span style=\"font-family: Lora;\">&nbsp;</span><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br class=\"Apple-interchange-newline\"><img src=\"assets/encyclopedia_2.png\" data-resizable=\"true\" style=\"box-sizing: border-box; max-width: 100%; height: auto; user-select: none; cursor: default !important;\" class=\"\"></span></h2><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">🌌 </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box; font-size: 20px;\">Core Identity of the Setting</strong></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box; font-size: 14px;\">The world is a </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box; font-size: 14px;\">dual‑realm cosmology</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box; font-size: 14px;\">:</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Earth</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, where humanity originates, fractured by war and later reshaped by crystal‑based technology.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Exodus (Ellavian/Gontha)</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, the </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">fae‑rooted dreamworld</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> where imagination becomes reality and where the actions of humans and Ancients ripple across galaxies.</span></span></li></ul><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">The two realms are linked through </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">the Books of Time</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Balance Crystals</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, and </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Gatebridges</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, forming a metaphysical system where cosmic law, magic, and prophecy intertwine. As the text states, </span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">“The vast worlds of the Extal galaxy are governed by the Sacred Books of Time… What transpires on Exodus… reflect onto Earth in dreams and imagination.”</em></span></p><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></h2><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">📚 The Cosmic Framework</span></h2><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">The Four Books of Time</span></h3><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">These books are the </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">cosmic operating system</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> of the Extal galaxy.</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Each book governs a different aspect of reality:</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Book of Time</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — records and regulates cosmic events; written by Father Time under Elyon’s command. </span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">“The hand of God is written on all four Books of Time and they obey His commands.”</em></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">The Curse</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — chronicles humanity’s fall and the consequences of their corruption.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Gate Bridges</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — contains the secrets of interworld travel and rewriting reality.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Prophecy of Dragons</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — reveals the fate of Dragonborn, humans, and the ultimate fall of Extal.</span></span></li></ul><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">These books are forbidden to mortals and guarded by Ancients.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">🔮 Magic, Power, and the Balance Crystals</span></h2><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">The Balance Crystals</span></h3><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">The Crystals are the </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">heartbeats of the fae worlds</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, stabilizing magic, nature, and even time.</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Your text notes: </span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">“Without the Crystals’ energy, all life on Exodus… would cease to exist.”</em></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Two major Balance Crystals—</span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Adrylin</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> and </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Tausa</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">—anchor the worl</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Tausa</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> was shattered, unleashing storms and earthquakes and allowing dark forces to steal its swords. </span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">“The results were worldwide earthquakes and wild storms… The swords… were taken by the Neverworld soldiers.”</em></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Adrylin</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> barely survived destruction thanks to Ardil, a chosen hero guided by angels and Ancients.</span></span></li></ul><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">The shattering of Tausa is one of the most important turning points in the world’s metaphysical stability.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">🐉 Races, Ancients, and Dragonborn</span></h2><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">The Ancients</span></h3><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Elves, dwarves, dragons, giants, phantoms, and other mythic beings originate from the dream‑essence of Exodus. They are the </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">firstborn of imagination</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, predating humanity.</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Dragonborn</span></h3><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">A hybrid race created through dark experimentation by James Faelivrin, later redeemed and elevated by Elyon.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">They become </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">guardians, emissaries, and peacekeepers</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> between humans and Ancients.</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Your text describes them as:</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><em style=\"box-sizing: border-box; font-family: Lora;\">“Redeemed with truth and Elyon’s own grace, they became the protectors of both ancients, native creatures and humans.”</em></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Their history includes:</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">A Holy War against Faelivrin</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">The founding of Dragonborn’s Realm in the Midlands</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">A civil war that nearly destroyed them</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Their eventual disappearance, leaving the world vulnerable</span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></h2><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">⚔️ The White Council and Human Corruption</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">The White Council is the dominant magical and religious authority among humans.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">They worship the </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Nine Gods</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, enforce magical law, and rewrite history to maintain power.</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Your text notes:</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><em style=\"box-sizing: border-box; font-family: Lora;\">“The White Council plays dirty… to go against them means dire consequences.”</em></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">They:</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Control magic through White Priests, War Mages, and Pentarch Wizards</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Persecute Wild Magic and Seekers</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Erase records of Dragonborn and ancient history</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Manipulate kingdoms through religious fear</span></li></ul><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">They are a major antagonist force in the setting.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">🌍 The Ages of Exodus</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Your document outlines a multi‑age historical cycle:</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Forgotten Age</span></h3><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Humans arrive on Exodus.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Faelivrin’s experiments create Dragonborn.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">A catastrophic war splits Gontha into Elise and Eden.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Technology is lost.</span></li></ul><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">1st Age — Chaos &amp; Holy War</span></h3><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Rise of the White Council.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Eskaver Garland wields the Dragon Sword.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Gontha is permanently divided.</span></li></ul><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">2nd Age — Knight of the Sword</span></h3><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Cynric Sherwin arrives from Earth.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Antioch is founded as a Christian sanctuary.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Dragonborn rescue ancient swords.</span></li></ul><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">3rd Age — Civil War</span></h3><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Dragonborn split and nearly fall.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Darkness spreads across Exodus.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">New horrors arise in Eden.</span></li></ul><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">4th Age — Crystal War</span></h3><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Tausa shatters.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Ardil warns Dragonborn of Scaron’s enslavement.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Darkness rises again.</span></li></ul><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Each age escalates the cosmic tension and moves the world closer to the prophesied collapse.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">🌞 Earth’s Parallel History</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Earth undergoes its own collapse:</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">A second civil war</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Loss of electricity</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Rise of </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Sinvin</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, a crystal‑derived energy source</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Emergence of </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">House Lords</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> and </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Universal Powers</strong></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Airships, steam‑crystal fusion, and new feudal city‑states</span></li></ul><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Your text states:</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><em style=\"box-sizing: border-box; font-family: Lora;\">“Sinvin is not to be trusted… its very essence is a tainted shard of the Balance Crystal found in the fae world of Gontha.”</em></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Earth’s fate is directly tied to the corruption of Exodus.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">🕳️ The Gods and the Fall of Heaven</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">The gods of Exodus are fallen spiritual beings who once ruled humanity.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Their corruption mirrors the corruption of humans and Ancients.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Your text describes their fall vividly:</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><em style=\"box-sizing: border-box; font-family: Lora;\">“Their hearts were continually wanting for man to suffer… they made humans build temples to themselves.”</em></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Elyon’s intervention, the imprisonment of the gods, and their later resurgence through Faelivrin form the theological backbone of the setting.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">🔥 Central Themes</span></h2><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">1. </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Imagination as Creation</strong></span></h3><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Exodus is literally shaped by human dreams and desires.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">2. </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">The Corruption of Power</strong></span></h3><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Humans, gods, and Ancients all fall prey to ambition.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">3. </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Cycles of Collapse and Renewal</strong></span></h3><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Each age ends in catastrophe, echoing the Books of Time.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">4. </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">The Fragility of Balance</strong></span></h3><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">The Balance Crystals are the lynchpin of all worlds.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">5. </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Prophecy and Destiny</strong></span></h3><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">The Dragon Prophecy foretells the fall of Extal and the final pilgrimage of humanity.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">🧭 Narrative Opportunities</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">This world is rich with story potential:</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Heroes seeking the lost Drugi‑ward</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">A quest to restore or rewrite the Books of Time</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Dragonborn returning from exile</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Earth discovering the truth behind Sinvin</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">A final stand to protect Adrylin</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">The pilgrimage back to Earth before the fall of Extal</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Conflicts between White Council loyalists and Wild Magic Seekers</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">The redemption arc of Ravage/Valandil Faelivrin</span></li></ul><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">If you want, I can now create </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">a structured encyclopedia entry</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">a timeline</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">a map‑ready regional breakdown</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, or </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">a character‑focused overview</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> based on this same material.</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">create a structured encyclopedia entry, a timeline, a map‑ready regional breakdown</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Here is a </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">fully structured</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">encyclopedia‑style</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">timeline‑driven</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, and </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">map‑ready regional breakdown</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> of your world, built directly from the uploaded </span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Dragonblood Encyclopedia</em><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> text.</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">All quoted lines come from your document.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><h1 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 2em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"></span><span style=\"font-size: 16px;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"></span><span style=\"font-size: 24px;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">📘 ENCYCLOPEDIA ENTRY: </span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">The Worlds of Extal &amp; Exodus</em></span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\"></em></span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\"></em></span></h1><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">1. Cosmology of Extal</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Extal is a multi‑world galaxy governed by four divine artifacts known as the </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Books of Time</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">. These books regulate cosmic law, time, prophecy, and interworld travel. As your text states, </span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">“The vast worlds of the Extal galaxy are governed by the Sacred Books of Time.”</em></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">The Four Books</span></h3><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Book of Time</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Governs the flow of time; written by Father Time under Elyon’s command. </span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">“The hand of God is written on all four Books of Time and they obey His commands.”</em></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">The Curse</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Records humanity’s corruption and the consequences poured out upon Extal.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Gate Bridges</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Holds the secrets of portal travel and reality rewriting.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Prophecy of Dragons</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Foretells the rise and fall of Dragonborn, the collapse of Exodus, and the final human exodus back to Earth.</span></span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></h2><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">2. Exodus (Ellavian): The Dreamworld</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Exodus is a world where imagination manifests into living beings. It is described as </span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">“the world between worlds… from which dreams are formed and mythology of man lives.”</em></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Native Races</span></h3><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Dragons</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — The master race of myth, symbols of divine authority.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Elves (Secondborn)</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Forest‑bound, magically attuned.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Dwarves</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Mountain‑dwellers, master smiths.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Phantoms</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Winged messengers of sky and order.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Giants</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Northern titans whose steps shake the land.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Others</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Centaurs, dryads, trolls, unicorns, nymphs, and countless dream‑born beings.</span></span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></h2><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">3. Dragonborn</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Created through the dark experiments of James Faelivrin, Dragonborn are part human, part otherworldly.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Your text notes: </span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">“Dragonborn was formed from the dark experiments James Faelivrin continued… it forever altered the men and women and their children’s children for all time.”</em></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">They later become:</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Protectors of Ancients and humans</strong></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Peacekeepers of Gontha</strong></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Gatebridge guardians</strong></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Central figures in prophecy</strong></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></h2><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">4. The Balance Crystals</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">The Crystals stabilize all life in Extal. </span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">“Without the Crystals’ energy, all life on Exodus… would cease to exist.”</em></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Twin Balance Crystals</span></h3><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Crystal of Adrylin</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Saved by Ardil after a massive conflict on Scaron.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Crystal of Tausa</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Shattered by Neverworld forces, causing global storms and earthquakes.</span></span></li></ul><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">When a crystal breaks, </span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">“the power of that crystal transfers to the swords… the one who wields the sword controls the magic… and part of the destructive nature of the world.”</em></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">5. The White Council</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">A powerful human religious‑magical order that rewrites history and suppresses truth.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">They are described as </span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">“growing in its greed for power… their version of history is even stronger.”</em></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">They:</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Control magic</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Persecute Wild Magic</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Manipulate kingdoms</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Erase Dragonborn history</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Serve the Nine Gods (fallen beings)</span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">6. Neverworld &amp; the Emperor of Night</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Neverworld is the realm of the dead, ruled by the Emperor of Night.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">His son, </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Valandil Faelivrin (Ravage)</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, becomes a pivotal figure seeking redemption.</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Your text: </span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">“He simply knows in his heart that he must follow… he knows it was an Amtuvo (angel).”</em></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><h1 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 2em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">📜 TIMELINE OF THE AGES</span></h1><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Forgotten Age</span></h2><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Humans arrive on Exodus.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">James Faelivrin conducts experiments, creating Dragonborn.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Dragonborn flee and ally with Ancients.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Faelivrin declares himself Emperor and unleashes a superweapon.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Gontha splits into </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Elise</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> and </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Eden</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, forming the </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Volesin Sea</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Technology is lost.</span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">First Age — The Holy War</span></h2><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Faelivrin wages war on Ancients.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Eskaver Garland receives the Dragon Sword.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Massive destruction reshapes the world.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Ancients withdraw from humanity.</span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Second Age — Knight of the Sword</span></h2><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Cynric Sherwin arrives from Earth.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Antioch is founded.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Dragonborn retrieve ancient swords.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">The White Council rises.</span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Third Age — Dragonborn Civil War</span></h2><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Dragonborn split into factions.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Darkness spreads across Eden.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">The last Drugi‑ward disappears, leaving Gatebridges unprotected.</span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Fourth Age — Crystal War</span></h2><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Crystal of Tausa is shattered.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Ardil protects Adrylin.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Dragonborn decline and lose faith.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Neverworld gains power.</span></li></ul><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br></span></p><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">1. Gontha (Pre‑Cataclysm)</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">A vast continent of mythic landscapes:</span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Percva’m Plains</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Unicorn herds and radiant temples.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Calmone</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Waterfalls and sea‑magic.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Fairy Lands</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Silas creatures, nymphs, and dream‑born beings.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Dragon Mountains</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> — Seat of Dragonborn power.</span></span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">2. Elise (Western Half)</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Formed after the destruction of Gontha</span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Human kingdoms rebuilt here.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">White Council influence is strongest.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Dragonborn presence diminished.</span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">3. Eden (Eastern Half)</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">The more corrupted half.</span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Site of Faelivrin’s darkest experiments.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Home to abominations and tainted lands.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Frequent Neverworld incursions.</span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">4. Volesin Sea</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">The massive waterway created by the cataclysm.</span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Center of trade and conflict.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Hides the Island of Tausa at its heart.</span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">5. Island of Tausa</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Invisible and unreachable without Drugi‑ward permission</span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Former home of a Balance Crystal.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Now shattered and corrupted.</span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">6. Scaron</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">A half‑dead continent.</span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Once home to the Emperor of Night’s empire.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Site of the Crystal of Adrylin.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Dragons reclaim it after Ardil’s quest.</span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">7. Dragonborn Realm (Midlands)</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">A fortified nation built within the Dragon Mountains.</span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Divided into provinces for each Ancient race.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Home of the Great Dragon Hall.</span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">8. Legend Island</span></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">Home of gods and servants of the Emperor.</span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Ardil flees from here after choosing Elyon.</span></li></ul><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><span style=\"box-sizing: border-box; font-size: 26px;\">C</span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box; font-size: 26px;\">haracter Compendium of Exodus &amp; Extal</strong></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">1. The Sherwin Line</strong></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">A bloodline repeatedly chosen by Elyon to stand against the darkness of Neverworld and the corruption of the White Council. Their story spans multiple ages and intersects with every major prophecy.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Cynric Sherwin</strong></h3><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Titles:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> Knight of the Sword, Founder of Antioch</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Era:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> 2nd Age</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Role:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> First Sherwin to enter Exodus; catalyst for Dragonborn’s resurgence</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Key Traits:</strong></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">A foreigner from Earth, “</span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">from another world, a world referred to as the Home World</em><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">.”</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Accidentally transported to Rumeran and forced into a divine quest.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Built the first Christian sanctuary on Exodus: “</span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Thus Antioch was formed on the east coast of Elise</em><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">.”</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">His father is revealed to be </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Vincent</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">, the Darklord of the White Council, a revelation that nearly destroys Dragonborn.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Eventually disappears, leaving his son Stephen to carry the burden of his legacy.</span></li></ul><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></h3><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Stephen Sherwin</strong></h3><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Titles:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> Reformer of Dragonborn</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Era:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> 3rd Age</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Role:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> Reunifier of Dragonborn after the Civil War</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Key Traits:</strong></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Leads the reformation of Dragonborn on Earth and Exodus: “</span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">bringing together all who were Dragonborn around Earth as well as Exodus’s scattered inhabitants</em><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">.”</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Haunted by Cynric’s disappearance and the tainted legacy of his grandfather Vincent.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Fights to reclaim the Crystal swords after Vincent taints one of the Balance Crystals.</span></li></ul><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></h3><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Vale Sherwin</strong></h3><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Titles:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> Bearer of the Sword of Dragon’s Fire</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Era:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> 4th Age</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Role:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> Warrior‑leader against Neverworld</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Key Traits</strong></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Regains the lost Sword of Dragon’s Fire: “</span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">he had earned the right to lead the creatures of Exodus and the Dragons themselves</em><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">.”</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Encounters Ravage at Tausa and becomes the catalyst for his redemption.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Targeted by the Emperor of Night because “</span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">he knew too much</em><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">.”</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Entrusts the Sword of Dragon’s Fire to Ravage for safekeeping.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Goes into hiding with the Sherwin family until the rightful time to reclaim the throne.</span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></h2><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">2. The Faelivrin Line</strong></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\">A bloodline marked by corruption, ambition, and tragedy. Their actions shape the darkest eras of Exodus.</span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">James Faelivrin</strong></h3><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Titles:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> Emperor of Exodus (self‑proclaimed), Father of Dragonborn</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Era:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> Forgotten Age</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Role:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> Creator of Dragonborn; architect of the Cataclysm</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Key Traits:</strong></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">A brilliant but corrupted scientist: “</span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">a greedy man… never pleased and wanting more</em><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">.”</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Conducts horrific experiments on natives and humans, creating the first Dragonborn.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Declares himself Emperor and High Priest of the Nine Gods.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Unleashes a superweapon that splits Gontha into Elise and Eden:</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><em style=\"box-sizing: border-box; font-family: Lora;\">“With a single press of the button, Exodus forever changed… Gontha was torn apart.”</em></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">His legacy becomes the root of all later darkness.</span></li></ul><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></h3><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Valandil Faelivrin (Ravage)</strong></h3><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Titles:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> Prince of the Emperor of Night; Ravage the Undead</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Era:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> 4th Age</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Role:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> Antihero seeking redemption</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Key Traits:</strong></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Known for terror “</span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">throughout the ages</em><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">,” his age unknown.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Reveals his true identity to Vale Sherwin: “</span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Prince Valandil Faelivrin, the prince of the Emperor of Night</em><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">.”</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Visited by an </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Amtuvo (angel)</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> warning him his days are numbered unless he changes.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Seeks Vale Sherwin’s guidance despite defying his father.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Provides secrets about the Emperor that no one knew.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Protects the Sword of Dragon’s Fire after Vale entrusts it to him.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">His redemption arc is one of the most emotionally powerful in the lore.</span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></h2><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">3. Ardil of Legend Island</strong></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Titles:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> Chosen of Elyon, Protector of Adrylin</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Era:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> 4th Age</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Role:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> Savior of the Crystal of Adrylin</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Key Traits:</strong></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">A boy with visions “</span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">spoken to by angels and Ancients</em><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">.”</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Not Dragonborn, yet chosen by Elyon to defend a Balance Crystal.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Flees Legend Island after choosing the Forbidden God (Elyon) over the gods of Exodus.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Undertakes a world‑spanning quest “</span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">through danger, forbidden love, and a wild quest leading to all parts of the world</em><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">.”</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Saves the Crystal of Adrylin, after which dragons guard it fiercely.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Disappears from history: “</span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">he disappears from the pages of history who get too close to the truth</em><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">.”</span></span></li></ul><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></h2><h2 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.5em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">4. Eskaver Garland</strong></h2><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Titles:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> First Dragonborn King, The Bizzerker, Wielder of the Dragon Sword</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Era:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> 1st Age</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Role:</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\"> Hero of the Holy War; cornerstone of Dragonborn prophecy</span></span></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Key Traits:</strong></p><p style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></p><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">A mortal man who becomes the first recorded Dragonborn hero.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Known for unmatched courage: “</span><em class=\"ql-font-lora\" style=\"box-sizing: border-box;\">he was quickly known as the Bizzerker</em><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">.”</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Prays fervently for protection so he can save others.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Chosen by Dragons to wield the Dragon Sword:</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><em style=\"box-sizing: border-box; font-family: Lora;\">“Eskaver was given the Dragon Sword… its power beyond understanding.”</em></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">His wielding of the sword enrages Faelivrin and escalates the Holy War.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\"><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Receives visions from Elyon that form the basis of the </span><strong class=\"ql-font-lora\" style=\"box-sizing: border-box;\">Prophecy of Dragons</strong><span class=\"ql-font-lora\" style=\"box-sizing: border-box;\">.</span></span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Vows to restore Dragonborn to Elyon’s grace.</span></li></ul><h1 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 2em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><span style=\"font-family: Lora;\"><br style=\"box-sizing: border-box;\"></span></h1><h1 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 2em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">﻿Character Relationships &amp; Intersections</strong></h1><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Sherwins ↔ Faelivrin Line</strong></h3><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Cynric is the son of Vincent (Faelivrin), making the Sherwins heirs to both light and darkness.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Vale Sherwin becomes the redeemer of Valandil Faelivrin (Ravage).</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">The two families are cosmically intertwined across ages.</span></li></ul><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Ardil ↔ Dragonborn</strong></h3><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">Ardil’s quest saves Adrylin, which Dragonborn later guard.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">His warnings awaken Dragonborn to the coming war.</span></li></ul><h3 style=\"font-weight: 600; letter-spacing: -0.02em; color: rgb(242, 242, 242); cursor: text; box-sizing: border-box; margin: 0px; padding: 0px; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; font-size: 1.17em; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><strong style=\"box-sizing: border-box; font-family: Lora;\">Eskaver ↔ All Bloodlines</strong></h3><ul style=\"cursor: text; box-sizing: border-box; margin: 0px; padding: 0px 0px 0px 1.5em; counter-reset: list-1 0 list-2 0 list-3 0 list-4 0 list-5 0 list-6 0 list-7 0 list-8 0 list-9 0; color: rgb(242, 242, 242); font-size: 14px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: left; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; caret-color: rgb(242, 242, 242); white-space: pre-wrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;\"><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">His prophecy shapes the destiny of Sherwins, Dragonborn, and the Faelivrin line.</span></li><li style=\"box-sizing: border-box; list-style-type: none; padding-left: 1.5em;\"><span style=\"font-family: Lora;\">His sword becomes the central relic of later ages.</span></li></ul></td></tr></tbody></table></div><p><br></p>",
