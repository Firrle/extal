  "characters": {
    "char_lyra": {
      "id": "char_lyra",
      "name": "Lyra Voss",
      "type": "character",
      "portrait": "🔥",
      "portraitImage": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMCAO7ZL2QAAAAASUVORK5CYII=",
      "firstName": "Lyra",
      "lastName": "Voss",
      "race": "Human",
      "age": 27,
      "gender": "Woman",
      "class": "Warden-Scribe",
      "personality": "Methodical, dry-humored, and stubbornly compassionate under pressure.",
      "background": "Raised in the Archive Vault, Lyra apprenticed as both route-cartographer and seal-keeper after surviving an ashfall collapse as a child.",
      "motivations": "Prevent another collapse, preserve true records, and prove that duty can coexist with mercy.",
      "tags": [
        "ember-weaver",
        "archive-trained",
        "field-leader"
      ],
      "bio": "<p><strong style=\"font-size:20px;\">Ashvale Compact • MTG Character Frame</strong></p><p>\n</p><p><em>Character Card: Lyra Voss</em></p><p>\n</p><p><img data-lore-image=\"char-lyra\" src=\"assets/alicia_alcorin.jpg\" alt=\"Portrait of Lyra Voss\" style=\"display: block; margin: 8px auto 14px; max-width: 100%; border: 1px solid rgb(109, 85, 48); border-radius: 4px; position: relative; cursor: default; touch-action: none; pointer-events: auto;\" data-resizable=\"true\" class=\"img-resize-enabled\" draggable=\"false\"></p><table style=\"border-collapse:collapse;table-layout:fixed;width:100%;border:2px solid #c8a24a;background:#1a1d22;\">\n  <tbody><tr>\n    <td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width:23%;vertical-align:top;border:1px solid #6d5530;background:#222831;padding:10px;\">\n      <h3 style=\"margin:0 0 8px 0;color:#f0d78a;\">Linked Items</h3>\n      <p><strong>Characters</strong></p>\n      <ul>\n        <li><a href=\"extal://item/character/char_bram\" class=\"extal-item-link extal-item-link-character\" data-item-link-type=\"character\">Bram Kest</a></li>\n        <li><a href=\"extal://item/character/char_sable\" class=\"extal-item-link extal-item-link-character\" data-item-link-type=\"character\">Sable Mire</a></li>\n        <li><a href=\"extal://item/character/char_oren\" class=\"extal-item-link extal-item-link-character\" data-item-link-type=\"character\">Oren Pike</a></li>\n      </ul>\n      <p><strong>Topics</strong></p>\n      <ul>\n        <li><a href=\"extal://item/topic/topic_world\" class=\"extal-item-link extal-item-link-topic\" data-item-link-type=\"topic\">Ashvale Compact</a></li>\n        <li><a href=\"extal://item/topic/topic_magic\" class=\"extal-item-link extal-item-link-topic\" data-item-link-type=\"topic\">Ember Weave</a></li>\n        <li><a href=\"extal://item/topic/topic_furnace\" class=\"extal-item-link extal-item-link-topic\" data-item-link-type=\"topic\">Furnace Oath</a></li>\n      </ul>\n      <p><strong>Timeline</strong></p>\n      <ul>\n        <li><a href=\"extal://item/event/event_black_dawn\" class=\"extal-item-link extal-item-link-event\" data-item-link-type=\"event\">The Black Dawn Breach</a></li>\n        <li><a href=\"extal://item/event/event_cinderfall\" class=\"extal-item-link extal-item-link-event\" data-item-link-type=\"event\">Cinderfall Convocation</a></li>\n      </ul>\n      <p><strong>Marker</strong></p>\n      <ul>\n        <li><a href=\"extal://item/marker/marker_oathstone\" class=\"extal-item-link extal-item-link-marker\" data-item-link-type=\"marker\">Oathstone Bridge</a></li>\n      </ul>\n    </td>\n    <td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width:54%;vertical-align:top;border:1px solid #6d5530;background:#1f242b;padding:12px;\">\n      <h1 style=\"margin-top:0;color:#f5e7b2;\">Lyra Voss</h1>\n      <p><strong>Role:</strong> Senior route warden and archive-certified breach sealer.</p>\n      <p>Lyra operates at the intersection of law, logistics, and crisis response. Her field doctrine is simple: preserve civilians first, preserve records second, preserve pride never.</p>\n      <h2>Operational Profile</h2>\n      <ul>\n        <li>Maintains seal integrity on Embermarch high-risk corridors.</li>\n        <li>Carries duplicate route records to prevent command forgery.</li>\n        <li>Activates Furnace Oath protocol when relay command fractures.</li>\n      </ul>\n      <p>During Black Dawn, Lyra personally sealed a pressure fault while convoy teams evacuated through ash crosswinds.</p>\n    </td>\n    <td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width:23%;vertical-align:top;border:1px solid #6d5530;background:#222831;padding:10px;\">\n      <h3 style=\"margin:0 0 8px 0;color:#f0d78a;\">Related Elements</h3>\n      <p><strong>Bond:</strong> Bound-by-oath partner with Bram Kest.</p>\n      <p><strong>Strength:</strong> High-pressure decision making under field collapse.</p>\n      <p><strong>Risk:</strong> Overexposure near unstable rift markers.</p>\n      <p><strong>Story Beat:</strong> Central stabilizer of Black Dawn response.</p>\n      <p><strong>Map Zone:</strong> Embermarch command corridor.</p>\n    </td>\n  </tr></tbody>\n</table><p>\n</p><p><br></p><p>\n</p>",
      "notes": "<p><strong>Field Notes:</strong></p><ul><li>Trusts Bram's instincts even when reports conflict.</li><li>Avoids long exposure at the Rift Gate marker after midnight.</li><li>Keeps three duplicate maps hidden in different districts.</li></ul>",
      "relationships": [
        {
          "targetId": "char_bram",
          "type": "Bound-by-oath partner",
          "notes": "Their patrol oath was signed during the Black Dawn breach; operational trust is high."
        }
      ],
