    "char_sable": {
      "id": "char_sable",
      "name": "Sable Mire",
      "type": "character",
      "portrait": "🧪",
      "portraitImage": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMCAO7ZL2QAAAAASUVORK5CYII=",
      "firstName": "Sable",
      "lastName": "Mire",
      "race": "Human",
      "age": 31,
      "gender": "Woman",
      "class": "Kiln Alchemist",
      "personality": "Sharp, curious, and relentlessly analytical.",
      "background": "Sable mapped pre-collapse kiln vents and now leads controlled venting experiments for Accord safety teams.",
      "motivations": "Prevent kiln cascades and prove that measured science can outpace panic.",
      "tags": [
        "alchemist",
        "kiln-mapper",
        "accord-witness"
      ],
      "bio": "<p><strong style=\"font-size:20px;\">Ashvale Compact • MTG Character Frame</strong></p><p>\n</p><p><em>Character Card: Sable Mire</em></p><p>\n</p><p><img data-lore-image=\"char-sable\" src=\"assets/white-magic-wizard.webp\" alt=\"Portrait of Sable Mire\" style=\"display: block; margin: 8px auto 14px; max-width: 100%; border: 1px solid rgb(109, 85, 48); border-radius: 4px; position: relative; cursor: default; touch-action: none; pointer-events: auto;\" data-resizable=\"true\" class=\"img-resize-enabled\" draggable=\"false\"></p><table style=\"border-collapse:collapse;table-layout:fixed;width:100%;border:2px solid #c8a24a;background:#1a1d22;\">\n  <tbody><tr>\n    <td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width:23%;vertical-align:top;border:1px solid #6d5530;background:#222831;padding:10px;\">\n      <h3 style=\"margin:0 0 8px 0;color:#f0d78a;\">Linked Items</h3>\n      <p><strong>Characters</strong></p>\n      <ul>\n        <li><a href=\"extal://item/character/char_oren\" class=\"extal-item-link extal-item-link-character\" data-item-link-type=\"character\">Oren Pike</a></li>\n        <li><a href=\"extal://item/character/char_lyra\" class=\"extal-item-link extal-item-link-character\" data-item-link-type=\"character\">Lyra Voss</a></li>\n        <li><a href=\"extal://item/character/char_bram\" class=\"extal-item-link extal-item-link-character\" data-item-link-type=\"character\">Bram Kest</a></li>\n      </ul>\n      <p><strong>Topics</strong></p>\n      <ul>\n        <li><a href=\"extal://item/topic/topic_sunder\" class=\"extal-item-link extal-item-link-topic\" data-item-link-type=\"topic\">Sundered Kilns</a></li>\n        <li><a href=\"extal://item/topic/topic_choir\" class=\"extal-item-link extal-item-link-topic\" data-item-link-type=\"topic\">Ash Choir</a></li>\n        <li><a href=\"extal://item/topic/topic_magic\" class=\"extal-item-link extal-item-link-topic\" data-item-link-type=\"topic\">Ember Weave</a></li>\n      </ul>\n      <p><strong>Timeline</strong></p>\n      <ul>\n        <li><a href=\"extal://item/event/event_black_dawn\" class=\"extal-item-link extal-item-link-event\" data-item-link-type=\"event\">The Black Dawn Breach</a></li>\n        <li><a href=\"extal://item/event/event_cinderfall\" class=\"extal-item-link extal-item-link-event\" data-item-link-type=\"event\">Cinderfall Convocation</a></li>\n      </ul>\n      <p><strong>Marker</strong></p>\n      <ul>\n        <li><a href=\"extal://item/marker/marker_quillfire\" class=\"extal-item-link extal-item-link-marker\" data-item-link-type=\"marker\">Quillfire Lab</a></li>\n      </ul>\n    </td>\n    <td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width:54%;vertical-align:top;border:1px solid #6d5530;background:#1f242b;padding:12px;\">\n      <h1 style=\"margin-top:0;color:#f5e7b2;\">Sable Mire</h1>\n      <p><strong>Role:</strong> Kiln alchemist and vent instability analyst.</p>\n      <p>Sable sits at the scientific edge of Compact survival. She quantifies kiln behavior, tracks resonance drift, and turns uncertain phenomena into actionable hazard thresholds.</p>\n      <h2>Operational Profile</h2>\n      <ul>\n        <li>Runs controlled assays at Quillfire Lab and Kilnheart Mouth.</li>\n        <li>Builds chemistry tables used by Ash Choir pre-tone alerts.</li>\n        <li>Supports legal opening of sealed annexes with evidence protocols.</li>\n      </ul>\n      <p>Her work during and after Cinderfall reframed kiln risk from superstition into measurable civic engineering.</p>\n    </td>\n    <td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width:23%;vertical-align:top;border:1px solid #6d5530;background:#222831;padding:10px;\">\n      <h3 style=\"margin:0 0 8px 0;color:#f0d78a;\">Related Elements</h3>\n      <p><strong>Bond:</strong> Research partner with Oren Pike.</p>\n      <p><strong>Strength:</strong> Converts field anomalies into reproducible data.</p>\n      <p><strong>Risk:</strong> High exposure to unstable kiln resonance.</p>\n      <p><strong>Story Beat:</strong> Key architect of post-breach kiln doctrine.</p>\n      <p><strong>Map Zone:</strong> Quillfire Lab and Sundered Kiln access ring.</p>\n    </td>\n  </tr></tbody>\n</table><p>\n</p><p><br></p><p>\n</p>",
      "notes": "<p><strong>Lab Notes:</strong></p><ul><li>Blue vent hums align with Ash Choir low tones.</li><li>Do not open kiln seals without two witnesses.</li><li>Needs Oren at Westwatch for stable relay reads.</li></ul>",
      "relationships": [
        {
          "targetId": "char_oren",
          "type": "Research partner",
          "notes": "Oren handles relay timing while Sable calibrates vent chemistry."
        }
      ],
