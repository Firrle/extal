    "char_bram": {
      "id": "char_bram",
      "name": "Bram Kest",
      "type": "character",
      "portrait": "🛡️",
      "portraitImage": "",
      "firstName": "Bram",
      "lastName": "Kest",
      "race": "Human",
      "age": 43,
      "gender": "Man",
      "class": "Road Captain",
      "personality": "Steady, practical, and blunt; prefers hard truths over hopeful guesses.",
      "background": "Former caravan guard turned Accord captain after escorting refugees through three winter closures.",
      "motivations": "Keep routes open for civilians and make the Compact less dependent on secret councils.",
      "tags": [
        "veteran",
        "route-captain",
        "accord-signatory"
      ],
      "bio": "<p><strong style=\"font-size: 20px;\">Ashvale Compact • MTG Character Frame</strong></p><p><br></p><p><em>Character Card: Bram Kest</em></p><p><br></p><p><img src=\"false\" data-resizable=\"true\" class=\"img-resize-enabled\" draggable=\"false\" style=\"position: relative; cursor: default; touch-action: none; pointer-events: auto;\"></p><table data-clear-border=\"1\"><tbody><tr><td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width:23%;vertical-align:top;border:1px solid #6d5530;background:#222831;padding:10px;\" data-clear-border=\"1\"><h3 style=\"margin:0 0 8px 0;color:#f0d78a;\">Linked Items</h3><p><strong>Characters</strong></p><ul><li><a href=\"extal://item/character/char_lyra\" class=\"extal-item-link extal-item-link-character\" data-item-link-type=\"character\">Lyra Voss</a></li><li><a href=\"extal://item/character/char_sable\" class=\"extal-item-link extal-item-link-character\" data-item-link-type=\"character\">Sable Mire</a></li><li><a href=\"extal://item/character/char_oren\" class=\"extal-item-link extal-item-link-character\" data-item-link-type=\"character\">Oren Pike</a></li></ul><p><strong>Topics</strong></p><ul><li><a href=\"extal://item/topic/topic_accord\" class=\"extal-item-link extal-item-link-topic\" data-item-link-type=\"topic\">Lantern Accord</a></li><li><a href=\"extal://item/topic/topic_furnace\" class=\"extal-item-link extal-item-link-topic\" data-item-link-type=\"topic\">Furnace Oath</a></li><li><a href=\"extal://item/topic/topic_world\" class=\"extal-item-link extal-item-link-topic\" data-item-link-type=\"topic\">Ashvale Compact</a></li></ul><p><strong>Timeline</strong></p><ul><li><a href=\"extal://item/event/event_black_dawn\" class=\"extal-item-link extal-item-link-event\" data-item-link-type=\"event\">The Black Dawn Breach</a></li><li><a href=\"extal://item/event/event_cinderfall\" class=\"extal-item-link extal-item-link-event\" data-item-link-type=\"event\">Cinderfall Convocation</a></li></ul></td><td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width: 54%; vertical-align: top; border: 1px solid rgb(109, 85, 48); background: rgb(31, 36, 43); padding: 12px;\" data-clear-border=\"1\"><h1 style=\"margin-top:0;color:#f5e7b2;\">Bram Kest</h1><p><strong>Role:</strong> Road captain and convoy continuity commander.</p><p>Bram translates policy into movement: he decides who moves, which route holds, and where supply mass shifts when roads break. His command style favors practical certainty over elegant plans.</p><h2>Operational Profile</h2><ul><li>Directs evacuation and ration flow under low-visibility ash weather.</li><li>Maintains patrol readiness with strict kit and wick reserves.</li><li>Anchors Accord discipline when political pressure escalates.</li></ul><p>In both Black Dawn and Cinderfall fallout phases, Bram held convoy tempo long enough for legal and technical teams to stabilize command.</p></td><td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width: 23%; vertical-align: top; border: 1px solid rgb(109, 85, 48); background: rgb(34, 40, 49); padding: 10px;\" data-clear-border=\"1\"><h3 style=\"margin:0 0 8px 0;color:#f0d78a;\">Related Elements</h3><p><strong>Bond:</strong> Bound-by-oath partner with Lyra Voss.</p><p><strong>Strength:</strong> Civilian-first convoy triage decisions.</p><p><strong>Risk:</strong> Often under-resourced during simultaneous route failures.</p><p><strong>Story Beat:</strong> Keeps road system functional during breach events.</p><p><strong>Map Zone:</strong> Outer Embermarch patrol loops.</p></td></tr></tbody>\n</table><p><br></p><p><br></p>",
      "notes": "<p><strong>Command Notes:</strong></p><ul><li>Dislikes ceremonial politics but obeys the Accord.</li><li>Keeps spare lantern-wicks in every checkpoint chest.</li><li>Will prioritize civilians over cargo in all route decisions.</li></ul>",
      "relationships": [
        {
          "targetId": "char_lyra",
          "type": "Bound-by-oath partner",
          "notes": "Respects Lyra's archival memory; defers to her on breach protocols."
        }
      ],
