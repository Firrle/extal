    "char_oren": {
      "id": "char_oren",
      "name": "Oren Pike",
      "type": "character",
      "portrait": "📡",
      "portraitImage": "data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAQAAAC1HAwCAAAAC0lEQVR42mP8/x8AAwMCAO7ZL2QAAAAASUVORK5CYII=",
      "firstName": "Oren",
      "lastName": "Pike",
      "race": "Human",
      "age": 35,
      "gender": "Man",
      "class": "Relay Marshal",
      "personality": "Calm under pressure, diplomatic, and meticulous with timing.",
      "background": "A former signal courier who rebuilt the west relay chain after the Black Dawn outages.",
      "motivations": "Keep every district reachable and prevent command fragmentation in crises.",
      "tags": [
        "signal-master",
        "westwatch",
        "accord-relay"
      ],
      "bio": "<p><strong style=\"font-size:20px;\">Ashvale Compact • MTG Character Frame</strong></p><p>\n</p><p><em>Character Card: Oren Pike</em></p><p>\n</p><p><img data-lore-image=\"char-oren\" src=\"assets/globe-1348777_1920.webp\" alt=\"Portrait motif for Oren Pike\" style=\"display: block; margin: 8px auto 14px; max-width: 100%; border: 1px solid rgb(109, 85, 48); border-radius: 4px; position: relative; cursor: default; touch-action: none; pointer-events: auto;\" data-resizable=\"true\" class=\"img-resize-enabled\" draggable=\"false\"></p><table style=\"border-collapse:collapse;table-layout:fixed;width:100%;border:2px solid #c8a24a;background:#1a1d22;\">\n  <tbody><tr>\n    <td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width:23%;vertical-align:top;border:1px solid #6d5530;background:#222831;padding:10px;\">\n      <h3 style=\"margin:0 0 8px 0;color:#f0d78a;\">Linked Items</h3>\n      <p><strong>Characters</strong></p>\n      <ul>\n        <li><a href=\"extal://item/character/char_sable\" class=\"extal-item-link extal-item-link-character\" data-item-link-type=\"character\">Sable Mire</a></li>\n        <li><a href=\"extal://item/character/char_lyra\" class=\"extal-item-link extal-item-link-character\" data-item-link-type=\"character\">Lyra Voss</a></li>\n        <li><a href=\"extal://item/character/char_bram\" class=\"extal-item-link extal-item-link-character\" data-item-link-type=\"character\">Bram Kest</a></li>\n      </ul>\n      <p><strong>Topics</strong></p>\n      <ul>\n        <li><a href=\"extal://item/topic/topic_choir\" class=\"extal-item-link extal-item-link-topic\" data-item-link-type=\"topic\">Ash Choir</a></li>\n        <li><a href=\"extal://item/topic/topic_furnace\" class=\"extal-item-link extal-item-link-topic\" data-item-link-type=\"topic\">Furnace Oath</a></li>\n        <li><a href=\"extal://item/topic/topic_accord\" class=\"extal-item-link extal-item-link-topic\" data-item-link-type=\"topic\">Lantern Accord</a></li>\n      </ul>\n      <p><strong>Timeline</strong></p>\n      <ul>\n        <li><a href=\"extal://item/event/event_black_dawn\" class=\"extal-item-link extal-item-link-event\" data-item-link-type=\"event\">The Black Dawn Breach</a></li>\n        <li><a href=\"extal://item/event/event_cinderfall\" class=\"extal-item-link extal-item-link-event\" data-item-link-type=\"event\">Cinderfall Convocation</a></li>\n      </ul>\n    </td>\n    <td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width:54%;vertical-align:top;border:1px solid #6d5530;background:#1f242b;padding:12px;\">\n      <h1 style=\"margin-top:0;color:#f5e7b2;\">Oren Pike</h1>\n      <p><strong>Role:</strong> Relay marshal and signal network authority.</p>\n      <p>Oren ensures that command intent survives storm noise, tower delay, and panic. His relay schemas coordinate alerts, route closures, and succession signaling under Accord constraints.</p>\n      <h2>Operational Profile</h2>\n      <ul>\n        <li>Maintains Ash Choir cadence integrity across district towers.</li>\n        <li>Schedules silence windows for secure high-risk deliberation.</li>\n        <li>Links scientific thresholds from Sable to real-time alarms.</li>\n      </ul>\n      <p>Oren's post-Black Dawn reforms made cross-district command transition faster and auditable.</p>\n    </td>\n    <td contenteditable=\"true\" tabindex=\"0\" role=\"textbox\" style=\"width:23%;vertical-align:top;border:1px solid #6d5530;background:#222831;padding:10px;\">\n      <h3 style=\"margin:0 0 8px 0;color:#f0d78a;\">Related Elements</h3>\n      <p><strong>Bond:</strong> Research partner with Sable Mire.</p>\n      <p><strong>Strength:</strong> High-fidelity relay orchestration.</p>\n      <p><strong>Risk:</strong> System-wide dependency on relay uptime.</p>\n      <p><strong>Story Beat:</strong> Added pre-tone warning standard after kiln surges.</p>\n      <p><strong>Map Zone:</strong> Westwatch and Blackbell relay chain.</p>\n    </td>\n  </tr></tbody>\n</table><p>\n</p><p><br></p><p>\n</p>",
      "notes": "<p><strong>Relay Notes:</strong></p><ul><li>Blackbell sequence now includes kiln surge pre-tone.</li><li>Bram trusts Oren on convoy diversion calls.</li><li>Sable and Oren co-author breach timing charts.</li></ul>",
      "relationships": [
        {
          "targetId": "char_sable",
          "type": "Research partner",
          "notes": "Their kiln diagnostics are paired by protocol and oath."
        }
      ],
