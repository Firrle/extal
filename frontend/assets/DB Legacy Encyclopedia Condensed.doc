color w:val="auto"/></w:rPr></w:style><w:style w:styleId="P19" w:type="paragraph"><w:basedOn w:val="wwHeading1"/><w:name w:val="P19"/><w:hidden w:val="on"/><w:rPr xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:color w:val="auto"/></w:rPr></w:style><w:style w:styleId="P20" w:type="paragraph"><w:basedOn w:val="wwHeading2"/><w:name w:val="P20"/><w:hidden w:val="on"/><w:rPr xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:color w:val="auto"/></w:rPr></w:style><w:style w:styleId="P21" w:type="paragraph"><w:basedOn w:val="wwHeading3"/><w:name w:val="P21"/><w:hidden w:val="on"/><w:rPr xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:color w:val="auto"/></w:rPr></w:style><w:style w:styleId="P22" w:type="paragraph"><w:basedOn w:val="wwHeading4"/><w:name w:val="P22"/><w:hidden w:val="on"/><w:rPr xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:color w:val="auto"/></w:rPr></w:style><w:style w:styleId="P23" w:type="paragraph"><w:basedOn w:val="wwNormal"/><w:name w:val="P23"/><w:hidden w:val="on"/><w:rPr xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:color w:val="auto"/></w:rPr></w:style><w:style w:styleId="P24" w:type="paragraph"><w:basedOn w:val="wwTitle"/><w:name w:val="P24"/><w:hidden w:val="on"/><w:pPr xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:adjustRightInd w:val="off"/><w:spacing/><w:ind/><w:widowControl w:val="off"/><w:pBdr/><w:ind/></w:pPr><w:rPr xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:color w:val="auto"/></w:rPr></w:style><w:style w:styleId="P25" w:type="paragraph"><w:basedOn w:val="default-paragraph-style"/><w:name w:val="P25"/><w:hidden w:val="on"/></w:style><w:style w:styleId="T1" w:type="character"><w:name w:val="T1"/><w:hidden w:val="on"/><w:rPr xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:color w:val="auto"/></w:rPr></w:style>
                <w:style xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0" w:type="character" w:styleId="Hyperlink"><w:name w:val="Hyperlink"/><w:rsid w:val="006A55B0"/><w:rPr><w:color w:val="000080"/><w:u w:val="single"/></w:rPr></w:style><w:style xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0" w:type="character" w:styleId="FollowedHyperlink"><w:name w:val="FollowedHyperlink"/><w:rsid w:val="006A55B0"/><w:rPr><w:color w:val="800000"/><w:u w:val="single"/></w:rPr></w:style>
                
                <w:style xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0" w:type="character" w:styleId="CommentReference"><w:name w:val="annotation reference"/><w:basedOn w:val="DefaultParagraphFont"/><w:semiHidden/><w:rsid w:val="007770B7"/><w:rPr><w:sz w:val="16"/><w:sz-cs w:val="16"/></w:rPr></w:style><w:style xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0" w:type="paragraph" w:styleId="CommentText"><w:name w:val="annotation text"/><w:basedOn w:val="Normal"/><w:semiHidden/><w:rsid w:val="007770B7"/><w:pPr><w:pStyle w:val="CommentText"/></w:pPr><w:rPr><w:sz w:val="20"/><w:sz-cs w:val="20"/></w:rPr></w:style><w:style xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0" w:type="paragraph" w:styleId="CommentSubject"><w:name w:val="annotation subject"/><w:basedOn w:val="CommentText"/><w:next w:val="CommentText"/><w:semiHidden/><w:rsid w:val="007770B7"/><w:pPr><w:pStyle w:val="CommentSubject"/></w:pPr><w:rPr><w:b/><w:b-cs/></w:rPr></w:style>
                
            </w:styles>
            
            <w:docPr xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:displayBackgroundShape/><w:view w:val="print"/><w:zoom w:percent=""/><w:defaultTabStop w:val="709.2887"/><w:docVars/></w:docPr>
            <w:body><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P24"/></w:pPr><w:r><w:t>Dragonblood Encyclopedia </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P19"/></w:pPr><w:r><w:t>Book of Records </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Volume 1 - Books of Time </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>Volume 1 - BOOKS OF TIME        The vast worlds of the Extal galaxy are governed by the Sacred Books of Time. What transpires on Exodus and other worlds within Extal ultimately reflect onto Earth in dreams and imagination. They are such powerful books that no man has glimpsed a single Sacred Book. They are held and guarded by some of the most powerful Ancients. Only one book is known to be kept by the ancient Dragon Tribes of Exodus.        The first volume tells of the four books as a whole as an overview of what is written plus the written word that governs the galaxies as well. This first book called, "Books Of Time," is never seen by anyone. It is beyond reach.        The Balance Crystals of Exodus house part of the energy that flows out of the ancient books. From the Crystals, all life is balanced on Exodus as it is the most sacred world in the Ancient Realm. Without the Crystals' energy, all life on Exodus as well as anywhere on any number of inhabited worlds within the galaxy, would cease to exist. All that has been known would vanish and cut the life blood of pure imagination from the firstborn.        The First "Book of Time" governs time within Extal. In certain parts of the Universe, time is slowed down or speeds up according to the laws governed by Father Time who lives in between worlds. In the Books, he writes what is told by God, the order of things to happen and when. The hand of God is written on all four Books of Time and they obey His commands. Such books are forbidden to man. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Volume 2 - The Curse </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>Volume 2 - THE CURSE        5,000 years ago on Exodus, the firstborn race invaded the world with their impure imagination and designs. With the firstborn's introduction of evil, death was whispered on the winds of all time, crippling and unbalancing the Ancient Home World and worlds within all of Extal.         The Ancients, knowing the protection of their own King Elyon was on this race, pleaded with man to make peace and stop the destruction their very presence induced. It went unheeded and turned many Ancients to darkness, avoiding all man.        The race of Dragonborn is part human and part other from the forgotten age when humans bargained with the gods of Extal and cursed themselves for all time.        Redeemed with truth and Elyon's own grace, they became the protectors of both ancients, native creatures and humans. It was told that with the Dragonborn's coming, a temporary balance would restore Exodus till a time that the books of time would be opened and written on by Elyon Himself.        The Second Book of Time, "The Curse," writes the account of man's evil. From the book, the curse is written and poured out upon Extal for man's evilness. Detailed in the ways of which the curse is brought, the book contains death and is forbidden to all. It has been written in a curse but is promised to be written in again to break the curse. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Volume 3 - Gate Bridges </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>Volume 3 - GATE BRIDGES        On Extal worlds, certain parts of the galaxy is linked via gatebridges, portals that connect two points within the system, created before Dragonborn or humans came to inhabit the galaxy. It's true orign is unknown but have been marked by Dragonborn's passing, including the Hight Latra symbols of their language among the most ancient of writings that even they do not fully understand.        The Third Book, "Gate Bridges," contains the secrets of traveling via the gatebridge. It is a book of power like all four books of time, therefore giving power to rewrite and reinvent certain things. It is housed in a </w:t></w:r><w:r><w:t>Great Temple in Dragonborn's Realm, under the protection of an Ancient who is not part of Exodus nor Earth and whose allegience is only to Elyon. It is a book that is to be given to the next Drugi-ward, the guardian of the Gates. At the end of the Third Age, the last Drugi-ward disappeared giving control of the gatebridge over to anyone, the book itself no longer controlling events and countering the darkness that comes from the deep dark. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Volume 4 - Prophecy of Dragons </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>Volume 4 - PROPHECY OF THE DRAGONS        The Fourth and final book is called, "Prophecy of Dragons." It is a long and almost forgotten tale. It is a story of what is to come through the ages. Nothing can change it's progress as it was decreed by Elyon Himself to the inhabitants of Exodus. It's tale marks Dragonborn's role as ambassadors for the humans, Elyon's chosen people. It tells of events that will predate certain dark times as well as ages of growth. Ultimately however, it tells of Exodus' own fall and the destruction of all Extal.        Nothing can hold this event back. It is said that Elyon spoke to the First King of Dragonborn, Eskaver Garland, in a dream and gave visions of what was to come. Writing these things down, Eskaver vowed before God to restore his own people back to Elyon's grace. It is told that in the end, a pilgrimage will be made by all humans out of Extal back to their homeworld before the darkness takes over. Still, going home will not prove good because with the fall of Exodus, Earth will finally be what the gods all want, theirs for the taking. In the human Bible, it would be recorded in Revelations.        The prophecy itself is divided in many sections, given to many different ages, to be held by the priests of Antioch and the Ancient Temple Priests. Each age is given a revelation and a condition by Elyon to return to Him. Even so far away from home, His eyes are always watchful of his chosen people. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P19"/></w:pPr><w:r><w:t>Summary of The Ages </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>1. Concerning The "Balance Crystals" </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>1. Concerning The "Balance Crystals"        It is recorded that at the end of the forgotten age, crystals were formed with the help of Ancients to stop the destruction of Exodus brought on by man's overwhelming power and hunger for knowledge. With this knowledge, man became too powerful for themselves to control their own desires and brought chaos onto the world. Destruction and death reigned down till Exodus shook to it's core threatening to implode. It is not known how but with the help of the Ancients, crystals were formed around the world. Within these crystals housed the magical ability to control the world's destructive nature.        Within each crystal on a continent (which can be one or more), there are swords that were placed within the crystals themselves. If ever the case was that a crystal were to shatter, the swords would be removed and prophecy would be invoked to an Ancient. The Ancient then would bring the swords to the bearer with whom Elyon (God Himself) indicated.        During the time of Stephen Sherwin, son of Cynric Sherwin, the White Council was growing in it's greed for power once more. From beyond the plains of the living, a general by name of Vincent wanted nothing more than the destruction of the living, the only goal of his master.        Thinking he had found one of the twin Crystals of Balance, he destroyed the crystal itself and took the swords.In turn, Dragonborn made war on their own home which Vincent had made residence in to retrieve the swords. If the swords were to ever reach Neverworld, the world of the dead, the already tainted swords would gain the Emperor a portion of the power he has always wanted but was never able to obtain through the dark magic.        The crystal swords are a part of the crystals themselves and hold the world of Exodus together. When the crystal shatters, the power of that crystal transfers to the swords. The magic is the sword and the one </w:t></w:r><w:r><w:t>who weilds the sword controls the magic of the sword and part of the destructive nature of the world.        Thus, is the reason prophecy is given to the Ancients to distribute the swords specificlly to certain people God chooses to hide the swords or to use them within reason. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>1a. CRYSTAL OF ADRYLIN:        There are two locations on Exodus that houses two massive crystals that govern all other crystals of Exodus. They are the Balance Crystals. If ever they are tainted or destroyed, the world will be changed forever. For milleniums, these twin crystals were hidden from everyone's knowledge, kept safe by guardians and magic.        In the 4th age, when Dragonborn was beginning it's decline, they abandoned one of their first calls.Ardil, a boy who had visions and was spoken to by angels and Ancients, became an unlikely hero not born of the dragon but chosen by Elyon to lead a war for one of the Balance Crystals.        On the half dead continent of Scaron, the Emperor of Night's empire stood in the living ages ago.On the still thriving living half of the continent but still haunted, the crystal is found and an army is being formed secretly by the darkness.         It was told that the Twin Balance Crystals were given over to both humans and Ancients to watch. Of Adrylin, the fault seems to lie with the elves, particularlly the Elliads when they discovered their dark brothers were indeed the Nithi. They may have abandoned Scaron completely and Adrylin altogether keeping only a few scouts to report back home from time to time. As to dragons who still recide on parts of Scaron, who knows their minds?         On Legend Island, home of the gods and servants of the Emperor, Ardil must flee when he chooses to side with the forbidden God and sets out on a quest to warn Dragonborn of the events taking place while they themselves are quietly wasting away in a madness that is threatening to take over their minds.        Through danger, forbidden love, and a wild quest leading to all parts of the world he never knew he would ever see, Ardil is a prominent player in the role of keeping the Crystal of Adrylin safe from destruction.        In the end, the Crystal of Adrylin is saved and once again protected and guarded fiercely by dragons who make it a permanent second home.        As for Ardil, he disappears from the pages of history who get too close to the truth. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>1b. CRYSTAL OF TAUSA:        At the very center of the Volesin Sea sits the Island of Tausa. It is not visible to the naked eye and cannot be accidently sailed into. It cannot be touched except by one who is granted permission by the Drugi-ward (gatekeeper). As the Drugi-ward controls the Gatebridge of which Dragonborn travels, he also holds the secrets of Exodus.        In the age that Dragonborn betrayed the royal House of Sherwin and exiled the family, they set in motion things that would play out to their own demise and catastrophic events.        It is with these events that darkness gained a foothold and the Drugi-ward himself was captured. With the faith in Elyon gone in Dragonborn, the hand of Elyon over Exodus was slowly retracting. The power once held, now was no longer there. The Drugi-ward, held in secret by Elyon Himself, could not be contained any longer. Neverworld found him and the secrets he guarded. The gatebridge was taken over and made unsafe for leasure travel. And with the capture of the Drugi-ward, the Island of Tausa was no longer under the Drugi-ward's protection.        With the capture of the Drugi-ward, Neverworld went for the Crystal of Tausa and shattered it whole. </w:t></w:r><w:r><w:t>With Dragonborn's own betrayal of the royal house, they sided with the White Council making themselves little more than puppets. The Island of Tausa was unguarded.        The results were worldwide earthquakes and wild storms that surged uncontrollably throughout the heavens that were not seen since before the Forgotten Age.        When it was discovered what had happened, it was already too late. The damage was done.The swords that were contained within the Crystal of Tausa were taken by the Neverworld soldiers. And this time, the swords taken were from a Balance Crystal that could destroy worlds. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>2. Concerning Vale Sherwin and Valandil Faelivrin </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>2. Concerning Vale Sherwin &amp; Ravage        There's an incident that occured at the same time the Crystal of Tausa was destroyed. This incident pertains to the bloodline of Sherwin and the bloodline of the Emperor of Night.        Ravage has always been known for his terror throughout the ages. His age is unknown but is ancient in human years.When Vale Sherwin of the exiled family regained the lost Sword of Dragon's Fire, he had earned the right to lead the creatures of Exodus and the Dragons themselves against Neverworld's war raging across Exodus.        Upon reaching the Island of Tausa, Vale found to his dismay the crystal shattered and the swords gone. It is also here that he meets Ravage once again for he has met the prince several times before in the past while doing his father's business. However, while doing so, Vale senses that something disturbs this otherwise undead prince.        Ravage proceeds to tell Vale his own story, breaking his long held silence through the ages, revealing his true origins as Prince Valandil Faelivrin, the prince of the Emperor of Night. When this shocking news has finished settling into Vale and his companions who are with him, Ravage tells his own story of how he has been visited by otherworldly creatures, not by Ancients but by beings far more powerful than any he has ever met before. They tell him that his days are numbered if his ways are not changed. There is still hope for him but he must seek out one named Vale Sherwin who will tell him more of what to do.        When Teldan, Vale's close friend, asks why Ravage chose to follow this creature's advice, Ravage replies that he simply knows in his heart that he must follow. Even if it is to defy the Emperor, he must ask Vale what it is he must do. He knows it was an Amtuvo (angel).        With Vale's help along with Teldan's, they begin to turn Ravage from the darkness he has served or more to the point acted as in Neverworld. At the same time, he gives over secrets of the Emperor that nobody has known of before.        Even so, it may be too late. Dragonborn is falling as it has been prophecied before. It has given itself to the White Council. The Royal House of Sherwin is exiled. The Dragons and Ancients are enraged at everyone but the Sherwins.        It seemed that within weeks, war seemed to quickly die out and the White Council won victoriously against Neverworld. That itself made no sense which Ravage explained. The White Council was intended to win without knowing. Magic was to be introduced into Exodus again on a wide scale. His father was setting the stage for something much bigger to come.        While they were walking down a hillside one day examing the bodies of the fallen, the clouds split revealing red thunder and charriots. Black winged monsters of no description whipped down to eradicate all in it's path including Ravage but most of all, Vale.It was decided from there that Vale was not safe at all. He knew too much and Ravage had put him in danger of the Emperor himself.         But at the same time, the White Council had gained too much power and as was told by reports, Dragonborn itself was being looked upon as the enemy.        With their faith gone and the Ancients unsupport, they were </w:t></w:r><w:r><w:t>helpless. Soon, Dragonborn would have to flee for their lives as would Vale and his own friends.        To Ravage, Vale gave the sword of Dragon's Fire to keep safe. It needed to be guarded and if need be, to guide the Ancients. War would come. And they needed to follow the sword. The sword was given to Ravage freely by Vale Sherwin. It would be known magically by the sword itself.        As for the Sherwin Family, they would go into hiding until the time was right to take the throne again </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>History of Gontha </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>~~ Before Humans        In the beginning, God created the Heavens and the Earth....The Second of Three Heavens is vast beyond understanding. It is a strange and untamed place where man was never meant to exist naturally. There is a place that borders all three Heavens within the Universe. It is from which dreams are formed and mythology of man lives. It is called Exodus by man but in it's own language, Ellavian.        There was once 2 main continents on the western half of the world. One was called Gontha, the other was called Sacris. It was a world of beauty and untamed wild magic where all creatures were born from man's imagination and under the ancient laws that govern the Universe. Upon the lands, creatures great and small lived the dreams of man and formed the imaginations fueling creation's ambitions where upon man became great or small depending on one's own imagination and extent of it.        Upon Gontha was formed the first half of the whole which governed the world and dreams with order, man's own dreams creating temples and monuments, structures great and small throughout all the lands as a testament to God's greatness in creation and man's form and deeds structured after God's own image. For man is God's greatest creation. He is God's own children where upon all creation bows in the awesomness of God.        From the Silas creatues of fairy lands and nymphs who play games forever to the plainlands of Percva'm's unicorn herds and fields of splendor and power of it's radiant temples to Calmone's waterfalls and magic of sea and land to mimic man's own ideas of beauty, all was set in order.        And into the lands of myth was formed the races of Ancients: Elves of the secondborn, formed partly in the image of man but whole only in the magic lands and forest meadows, Dwarves: smaller than elves and stubborn to a fault, craving all things metallic and rock who's mountains are the glory of God. Into the reaches, they delve to create masterworks to sparkle in the golden sun to behold the power of Ellavian's crystals, Phantoms: the winged messengers of earth and sky who travel the clouds with thoughts of order and splendor, Giants: beasts akin to elves but taller and walks the northern territories with trembling stones announcing their presence, Dragons: the master race of all mythology who's very presence is God's reminder of authority over all creation.        There are many more creatures such as centaurs, dryads, trolls and all that man has dreamed since the beginning of creation. Ellavian is filled with history of mythology and testaments to God's wonder and imagination worked out by man's own dreams. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>~~ After Humans        At the beginning since Adam and Eve broke the universal wholeness with one greed of sin, all of creation tore apart; for man was meant to be the heirs of God, children of creation but above angels, rulers under God's own High Command. When sin entered the perfection of Earth, all creation groaned with the taint of evil, the lack of God. For where evil exists, God cannot be in it's presence nor it in His. For Light destroys all that is dark. And Adam damned the heirs of God to lives of darkness.        With provision made for humans alone for what was done, no other creation is granted mistakes. Humans alone are blessed as children unto God and forever are protected when the eyes are opened.        But man through the centuries are historically wicked at heart, touched by darkness and it wanting humanity to </w:t></w:r><w:r><w:t>die in ignorance of grace. So when man achieved what he thought impossible, with man was carried the taint of evil even to the world between worlds, the dreamworld of Exodus as man has such named it for themselves.        In the beginning, man was curious and filled with awe at the new and unexplainable things seen. Here was a world where they could live and breath without aid. Here also was energy in a form he could not understand.        So began man's existence on Exodus, creating a city and colonizing the world, exploration teams spreading in all directions.Still...it was not enough for one man, the leader of the expedition.        James Faelivrin was a greedy man given to temperments and outbursts, never pleased and wanting more.When he saw that Gontha housed many energies he could not understand, he spent all of his time studying the creatures of which were part of this energy, enslaving and torturing to understand what made them exist.        History is uncertain what exactly turned James Faelivrin but he did turn and in a dark way upon which the main scientific community questioned his ethics and morals. Given to drink and darker deeds, he was soon banned from the city of lights, the largest city that expanded over the years since man first came to Gontha.        From the pages of history it is recorded that Dragonborn was formed from the dark experiments James Faelivrin continued though it is never clear as to how other than that it forever altered the men and women and their children's children for all time.In the later years of the Forgotten Age, Dragonborn escaped the prison they were part of within the mind and out, controlled by Faelivrin's first of many creations of abomination.         Fleeing Faelivrin's built up city, they wandered as nomads in the wilderness and seeing for the first time the effect man's own presence placed on Exodus' natives. Death was the reward for man's coming, the taint of sin touching all life, killing many native beings of magic and beauty.        For many years, the first Dragonborn fled from the wrath of Faelivrin and divided into several tribes, always connected via the mainframe. In this way, they kept watch over each other at great distance and informing of Faelivrin's rage and determination to take them back. Dragonborn after all was Faelivrin's greatest achievment...and threat.        After the third Council of Elders, Dragons and a few others of the most powerful Ancients came together to form a treaty with Dragonborn. It was clear that they were not like most men who now populated much of Gontha. Also, a Phantom was given a message to deliver to the Elder Council by the hand of Elyon Himself.        Soon after, Dragonborn as a whole sided with the Ancients forming the first treaty of man and Ancients. More specifically, Ancients and Dragonborn as emmisaries between both sides. Under cover of magic man never could attain, which infuriated Faelivrin, Dragonborn was lost to Faelivrin's ever determination to find his lost experimental subjects.         In this time, with the help of many Ancient races, the first Dragon Palace for human inhabitation was created. Large by any normal man's standard, it was built this way for the purpose of housing all Ancient races including giants and Dragons. Each province of the Dragonsrealm is divided into territories large enough for many tribes of the same nation without crowding.        It fell to Dragonborn to create a system of government headed by Dragons and Dragonborn. To each province then was placed a guardian, ancient or human to be Lord of the lands and a speaker for his or her subjects in the Great Dragon Hall where all things were discussed.        The country was also designed to withstand attacks from outside. Fortified with a wall, the entire country was built within the Great Wall upon the Dragon Mountains in the Midland Region. . -=o§o=- .         For 500 years, things seemed to work out well. Dragonborn kept to an ordered system and became known throughout Gontha as Peace Keepers. Families were born and continued the legacy began with their forefathers, each living a great long life, greater than </w:t></w:r><w:r><w:t>many normal humans.        At the end of 500 years though, an uprising came from all corners of the continent. Greed tainted many man's heart for the source of power within the Ancients. Man beheld the wonders of magic and wanted it for themselves to control. Thus began the first of many dark wars that have forever been lost to man. It is now chronicled in the Ancient Dragonborn Journals in the Hall of Records.Within this record, it tells of man's dark choices and the beginning of man's turn to other means to control elements of Exodus.Gods, they believed, spoke to them in dreams, promising great power that equaled or even mastered over the Ancient races.At the head of this, Faelivrin came out and claimed himself the Emperor of Exodus, the High Priest of nine gods who told him secrets of the Ancient order. Few believed his claim but his reputation was known throughout the entire vast continent.To get the attentio of the scientists who had followed after their own forefathers, Faelivrin made an example of them by casting lightning down upon them all burning them alive on the University steps for all to see via comports. Here ended the greatest scientists upon Exodus.        From here, Faelivrin raised army after army and began a march throughout all of Gontha to imprison or irradicate Ancients claiming they were tainted with evil.        From within Dragonsrealm, the Council was heated in debate. Under universal law, Ancients were forbidden to harm humans as they were made in the image of the Creator and His children.        It fell upon Dragonborn to decide their involvement in Faelivrin's extermination process. Faelivrin had gained much power over 500 years and also something else that spelled death to many Ancients. To walk near Faelivrin was instant death for what was now part of him. A black magic was being called from the real powers that now converged on Exodus making it their second home.It became clear then what was needed.        With the help of the master dwarf smiths, the magic of the elder elves and the deepest magic of Dragons, a single sword was created of flame and blood. Magic in all ways, it held vast power. Now all that was needed was to choose who to wield the weapon.For many weeks it was undecided and with these weeks, Dragonborn went to war against Faelivrin head on. In the chronicles, it is titled "The Holy War." For it truly was more than a mortal fight. It was the war of gods.        He is simply called Eskaver. Nothing much is known except he led many people who were caught in the middle of the war. Thinking more for their safety, Eskaver led many ventures into small towns, guns blazing all around. Faelivrin had little care for his own people. He would cut them down if they were in his way to capture an Ancient being.        It fueled Eskaver with rage and he was quickly known as the Bizzerker. Of all men, he seemed to be untouchable and was. For within his heart, he prayed feverently to be kept safe only so that he could save those from Faelivrin's slaughter.        One day when he was rescuing a city from the inevitable tide of abomidable creatures created by Faelivrin, two other Dragonborn approached him in the fields, two senior dragons carrying them on their backs which was seldom seen.It was decided. Eskaver was given the Dragon Sword.        It should have turned the tide with the power of magic at Eskaver's finger tips. But what it did was infuriate Faelivrin. Here he was fighting to attain the magic for himself and traitors who he created to be more than they ever had been was given this magic.In a blind madness, Faelivrin stepped up the war, massacering all in his way. Rivers flowed with blood and the body count of innocents were higher than any human could stand. Those that had willingly sided with him deserted and went into hiding as all things living did except those who opposed his dark army.         History forgets the event but evidence is on maps. With his furious rage, Faelivrin abandoned reason and listened to darker words, succuming to a decision he wouldn't have made till then. Drawing all the forces together into one field, enemy and his own alike, from the heavens, he had built a </w:t></w:r><w:r><w:t>ship of exploration. More than exploration though was the weapons that were designed before all the scientists were killed off. It was a bomb that made the Atomic Bomb look simple in comparison.        When each force of the war was gathered, he let the dark dreams of madness take hold. With a single press of the button, Exodus forever changed.         Light and darkness collided and bled as fire and the dark creation of man exploded. Nobody was safe as the weapon hit ground. It spread like a volcanic plate beneath the ground, shifting back and forth till all things were swallowed whole by a gaping hole spewing fire. It did not end however but kept on spreading like a disease upon the very land, eroding earth and all that was in it's path. Water from the north and south crashed inward with billowing steam as Gontha was being torn apart faster than could be imagined. From north to south, the split in the ground was almost instantanious. East and west, the ground fell apart bit by bit with earthquakes tearing the land apart till after three full days, all that remained was a giant mass of water where once Gontha stood whole. The armies of both sides had vanished within the waters.        From that day forward, Ancients turned inward making little to no contact with any human. For man, he renamed Gontha "Elise" for the western half and "Eden" for the eastern half. Between the two halves, they named the waterway the "Volesin Sea." It was a time of great mourning for loss of more than lives.        Technology that once existed was forever lost by the destructive nature Faelivrin used in his weapon. For it wiped out all power on both sides of the once Gontha. It was a time of reinventing man's life from that of a great and powerful people to helpless people lost to their precious electrical power that was the lifeblood of civilization. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>1st Chaos War </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>1st Chaos War: The first Chas War was fought in the forgotten age when technology still existed. After the scientists took control of what they could claim of Exodus's largest continent, Gontha, they made themselves gods. The colonies revolted fiercely bringing about the destruction of all technology and bringing in the first age of Exodus. In this age, the people simply returned to the Medival times of Earth. They set up rulers to govern over local affairs.When this happened, the natives of the land simply drew apart from the colonies but was not yet cut off. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>1st Age: Age of the 2nd Chaos War / Second Holy War </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>1st Age: Age of the 2nd Chaos War / Second Holy War         The 1st age brought about the White Council, the aftermath of the Forgotten age where Dragonborn fought fiercely against Base, the colonized dark and magical realm of the High Council. As the 1st age dawned, the High Council of Base was silenced for a time. It was thought the great wars of Chaos was over. But in the middle of the millenium, 1500 years after, the White Council grew in power becoming popular once again. Thus the beginning of the Holy Wars was started.         It didn't grow popular till the middle of the millenium. Through it, Christianity practically died away. In it's place magic swarmed the everyday lifestyle and the White Council was the temple dedicated to almost every god the priests could come up with. They did this only to bring power to themselves and rule over Elise. They had little knowledge of the power they could command till later.         As the decades passed, the White Council grew as it's priests became gods in their own right. From all across Gontha, natives swarmed into a madness never seen before or since in the land. They besieged the White Council along with a certain human known only as Eskaver Garland. He was the first Dragonborn to appear in the history of Exodus in written form. In his hand was a sword of unnatural fire; it's power beyond understanding. With it he marched on the White Council with the aid of the unnatural allies, </w:t></w:r><w:r><w:t>those who feared humans, the natives.         Blood ran freely throughout Gontha as the Holy Wars brought forth revolts from all across the continent of Gontha. The people were split in half. For and against the White Council. Those who supported the White Council were those who saw the power of magic and how it could affect them for the good of all. They had in mind a better place, a place governed totally by magic and the White Council's seemingly innocent ways. Those who had been on Exodus before humans arrived knew the difference though and were terrified of this unnatural magic humans wielded. It was the most bloody war and also the war that split Gontha in two parts in the frenzy of a war gone mad.         Gontha was forever changed into the continents of Elise and Eden with the Volesin Ocean dividing the two. The name 'Gontha' is not even known today to anyone due mainly to the fact that most of the early writings of Exodus history is written primarily in the ancient Latra script. None but a very few know this language because it's a dead language. Those who speak it are the ancients and the few giants, elves and others who survived the coming of humans that marked the end of their own lives through the taint of man's heart. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>2nd Age: Age of the "Knight of the Sword" </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>2nd Age: Age of the "Knight of the Sword"         The 2nd age is the age of Dragonborn in most historian collections. The term "Knight of the Sword" is not understood to most people except Dragonborn who guarded it's meaning. It's the age of Cynric Sherwin, a foreign stranger to Rumeran.         His tale is lost in most accounts being it's blasphamy against the 9 gods. In it, records show he was from another world, a world refered to as the Home World where all mankind came from. This is the total opposite of what the 9 gods of Exodus say. They say that each of the 9 gods created certain men and women along with the creatures of Exodus called natives. Though it is considered cruel, the 9 gods make war agaisnt each other, wanting to be the higher god. So they include man in their game of chess moving the inhabitants of their created world according to their will. Those who pray to certain gods, the gods bless. The gods who don't get the prayers are angered and make life miserable. So in most cases, the calendar of Exodus was devised for the civilized countries that are under the White Council. Thus they are able to pray to all 9 gods to appease their wrath.         Cynric's tale is told of how he was tricked into stepping into a portal ending in the land of Rumeran. There he was forced to rescue the Princess whose god had declared her to be a sacrifice for her people because she had turned against him. Throughout the tale, Cynric is given the name "Knight of the Sword" though he knows nothing of Dragonborn's history.         When understanding comes at last after some years, he built the 1st sanctuary of Christains who were the minority and the hunted by magical beasts and dark plots in all the civilized countries. Thus Antioch was formed on the east coast of Elise, obscured and barred by a desert land full of death. The desert is called the Wilderlands, south of the Verlone forest and north of the country of Dunland. It is a testament to the 1st age of the Holy Wars; the lands there scarred beyond recovery. No man or animal lives there if not necessary.         The White Council was powerful though. So powerful terror ran through man's hearts, even those who worshipped the gods of the White Council. It wasn't long before Anitoch was found and the inhabitants fled.         In another story, Dragonborn is said to be on the Home world where several of the refugee's fled to by the power Cynric posessed. Vincent, the Darklord of old, high priest of the White Council demanded revenge against Dragonborn. What is truly stunning is Vincent is the father of Cynric Sherwin. This evidence almost destroyed Dragonborn when they were rescuing the ancient Swords of Dragons Fire. They stood firm in the end though and guards remained at the entrance of the </w:t></w:r><w:r><w:t>Crystal temples, the most ancient but forgotten buildings. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>3rd Age: Age of the 3rd War of Chaos </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>3rd Age: Age of the 3rd War of Chaos         The 3rd age is a dark age in Exodus' history. Dragonborn is known as the protectors of Exodus as are their brothers, the Guardians that recided in Scaron. But in the year of "3100" of the 3rd age, the realm of Dragonborn split in two causing a Civil War between brothers.         The ancient realm of the Highlands of the Midlands crumbled on itself as the Forbidden God was forgotten. Several fractions sided finally with the White Council, seeing the Council's power as did those in the early days of the Holy Wars. Thus Dragonborn feuded with each other. Angry that brothers would side with the ancient enemy of so many thousands of years, the war took on a new form, one that stripped apart Dragonborn's realm with power of technology. On the Home World even, battles took place in space far from the eyes and ears of the majority who knew nothing of Dragonborn's existance. In the end, Dragonborn fell on itself, the war ending the protection of Exodus.         Several centuries later, around "3500", Dragonborn reformed itself on the home world bringing back those who had turned away. Some brang with them pasts shrouded in darkness and misery that scarred their hearts and souls. It was an age of mourning, of silent understanding. Several doned black clothing for most of their lives identifying with the horror of what happened when embracing the darkness.         In the lead of heading up the reformation of Dragonborn was Stephen Sherwin, the son of Cynric Sherwin of the 2nd age, bringing together all who were Dragonborn around Earth as well as Exodus's scattered inhabitants of Dragonborn. He drew them together with his own compassion and own trials being faced with the past and the ever watching of his father's decline since the discovery of his own heritage of the ancient enemy. He had long since disappeared and Stephen dealt with it all.         One day though, after rescuing a police officer who had gained unusual information concerning Dragonborn's Castle on Exodus, Cynric appeared to him and those with him briefly. They had learned of the Darklord's residence in Castle Dragonborn along with the horror of his attempt to take the one of the Crystals of Balance that sustained life on Exodus. With his touch, the Crystal forever was tainted. He had also retrieved the swords found in the Crystal for his own use. Dragonborn thus made war upon their own realm again to rescue the swords and to take back their land.         Through the years since, Exodus knew no peace. Because of the disappearance of Dragonborn for a time, darkness swarmed over the lands with it's magic and influence. Races of men changed in ways unheard of, terrifying to some extents. On the continent of Eden just for example, Soalmin, once bordermen protecting the coasts and mountains of the west changed drastically into the most feared of all warriors, devising and perfecting tortures and the total enslavery of man. The Usilian Wars speak of this when King Usilian came to the throne of of Cavor.         The 3rd age closed with Dragonborn still not as strong as in the earlier days but still retained outposts and the rebuilt Kingdom of Dragonborn in the Midlands. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>4th Age: Age of the Crystal War </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>4th Age: Age of the Crystal War         The 4th age was given to blindness and the ever increasing darkness as Dragonborn tried desperately to hold onto their outposts in lands that were outside of Midland. A tale is kept in the vaults of Dragonborn.         Ardil, a lone wanderer, had been given a task of utmost importance. He must deliver a message to the Dragonborns. From Legend Island, his home, to the Tarkon valley near Silver lake on Eden, he travels and makes friends who will stand beside him in the darkening days. One such is an elf princess, one who's love for him is unmatched though the elven nation of Ardol would be </w:t></w:r><w:r><w:t>furious at such a notion. But circumstances make her flee her own homeland for fear of death, not because of her love for Ardil, but because she has turned her back on Tarris, the star god and the god of the elves. For joining with the Forbidden God, she has sentenced herself to death even as a princess.         The 4th age increased in darkness with the rise of Vincent once again, thought to have died when Dragonborn was taking back their realm. Yet he was alive, his new realm born out of Tausin who's history should have made people suspicious.         As legend goes, Tausin use to be the realm of prosperity and power. All throughout Scaron, Tausin was known as the empire of dreams. It was here that wisdom and knowledge was taught. The legend splits into many different stories and forms that concludes with the empire of Tausin changed somehow into a mysterious place shrouded in darkness. After a time, the legend of Tausin ceased to say more. Ages passed since any human stepped foot beyond the Gates.         There was only one way into the realm of Tausin. It was through the Gates of Darkness. Rumors of the gate's name are as many as the legends of Tausin itself. The most favored one though is that the greed and power of such knowledge from Tausin's extensive libraries and schools proved deadly. From beyond the grave, death swarmed through the entire empire striking out with plagues and an unholy power. When over, fear swept through the lands beyond Tausin and a gate was erected.         A single key was made that would open the gate. It wound through tunnels and mines that exited into the outer empire's deserted landscape. Where the key was stored was never told. To even open it would require a skill that none possessed any longer. The knowledge of such things died out with the steady decrease in dwarf smiths that use to build nearby. Since then, even the dwarves became legends, forgotten by time. Tausin was forgotten; it's dark past never fully discovered.         Thus Exodus's 4th age grew in darkness as Tausin's darkness enslaved all of Scaron save Adrylin. Here, Dragonborn fought hardest of all, keeping back the enemy from the Crystal's temple. As is, each continent has a crystal of balance. The location of the two central Crystals of course are unknown. But they fought to preserve Exodus from the devesation that nature would bring harder on Exodus if even one crystal should shatter.         Ardil's effort to reach Dragonborn with the message was because all other efforts from Dragonborn on Scaron to reach home failed in what could only be described as by the power of darkness not wanting it to be known. Thus until Ardil had given the message to Dragonborn, they knew nothing of what went on on Scaron.         This new knowledge made Dragonborn step up on their own forces, making ready for the inevitable. They had waited too long. Scaron had been enslaved for centuries now, no word ever escaping as to what had happened. Now they prepared for the next coming war... </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P19"/></w:pPr><w:r><w:t>THE WORLD OF EARTH </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>OVERVIEW </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>OVERVIEW         The United States fell after a second civil war over political heat and the people's anger. Amidst this war, a strange thing happened. A radient bright light washed over the land from east to west. When it was gone, everything that was powered by electricity stopped functioning never to return again. This plunged the war torn states into a dark age where murder and greed ran the streets. There was no order.         Then came the dawn of Sinvin, a strange oily substance that could be mined from harvested newfound crystals throughout the land. This restarted the economy but it was never what it use to be. America was sent back to the days of steam power.             After several hundred years, the roads became abandoned and bridges fell. New smaller roads were put into place. There was an order to things.                 The rich class: Those who controlled cities with power of crystals.         The </w:t></w:r><w:r><w:t>poor class: Those who worked the mines, factories and fields.             There was no central government any longer. States were their own country and cities were their own power so long as they paid the state country. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>People and Religion </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>PEOPLE AND RELIGION         Earth has many different people and religions. In the post united states where the story takes place, the people has lost hope. Religion in Gods are all but extinct. The thought of a deity in the post dark ere poses anger and hatred towards any who speak of it.         There are a few countries in the North Americas where religion is less restricted but they are hard to find and not well broadcasted. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Structure of Government </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>STRUCTURE OF GOVERNMENT         America has no centeral government. The government is run by the state countries. Each state country makes their own laws though they are usually similar to each other.         There is a central capital where the countries' affairs are discussed and dealt with. They are still elected to office but hold very little say in a person's life. The capital's power extends only to the countries well being. A person's life is in the care of a city or town. If the city itself cannot deal with the person, only then will the person be transfered over to the government to pass judgement.         This holds the same in all areas of life of a country whether it be a person's life or job placement. The structure of government holds that the state head has no power. The city has the power. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Cultures and Lands </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>CULTURES AND LANDS         The United States is split into many cultures. Since the reformation of the Americas in the Crystal Age, a new culture of people emerged. These are a fanatical people who are more in line of a cult. They worship the sun.         For thousands of years, the cultures of the United States were very diverse.          When the country fell and state countries replaced the union, a pilgrimage of various people migrated to form towns where the people had the same ideals and customs. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Transportation </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>TRANSPORTATION         For the longest time after the United States fell, there was no transportation of any kind. This was a secondary cause of economic failure. Without cars or any type of motorized transportation, there was no way to get to the cities that were now days and weeks away.         The steam engine train was brought back into commision 100 years later. The railroad system became the first interstate job that brought the economy back.         From state country to state country, the railroad recrossed America.         When Sinvin was introduced and the properties of the new crystal was discovered, it brought in a new era of economy as well as transportation.         Airships were the new invention of transportation. With the power of the crystal, it's power was harnessed to fuel airships, ships built to fly. With the fusion of steam and crystal, the airship became the dominant transportation vehicle. It was faster than the steam engine and was constantly being reinvented.          Airship Yards were built and a new Era of transportation began. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Economy </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>ECONOMY         The fall of the United States collapsed the economy to a complete standstill for over 75 years. In this period of time, much of the population of the new state countries died from various causes relating from malnutrition and sickness.         When the steam engine train was finally recommisioned, it brought the first real jobs to a crippled land. From railway crews to building stations and maintaining, the train system restarted the defunct economy. With the </w:t></w:r><w:r><w:t>rail system now connecting cities to cities, it brought in customers.         It wasn't until Sinvin was introduced by strange traders that a new era began. The properties of Sinvin in it's oil form was energy for a multitude of things. It could heal diseases, make things last longer, and give a longer life to the steam engines.         It wasn't until a new kind of crystal was discovered that it's properties became apparent. It's nature to give off energy was first examined extensively before realizing just how powerful the internal core of the crystal was. This then began the invention of the next major vehicle. The Airship.         With the combined fusion of steam and crystal core, the airship was the next major invention of travel.         With this new found power and invention, mining companies sprouted up overnight.         The economy boosted again as the next era began as the Crystal Era. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P19"/></w:pPr><w:r><w:t>THE WORLD OF EXODUS </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>MAIN OVERVIEW </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>OVERVIEW        Exodus co-exists with Earth as part of the 1st House of Dragonborn. Whereas Earth is where humans originated, Exodus is where magic of imagination and dreams began. All of mythology came from Exodus' vast Ancient cultures from dragons and dryads to the centaurs and faries.         They often crossed over into our world yet still masked by the Hidden Realm of Myra.         Over the course of human history on Exodus, the magic that once permiated all of Exodus slowly faded as Ancients departed behind the Tera Veil.         Each major country of Elise and Eden were first the High Seat of Ancient races.         In the 5th Age, Ancients saw how much man wanted the power of magic. But with the White Council's greed came a shadow of darkness. This was choking the magic essence of the Ancients and destroying the world.         As a whole, the Ancients began to rethink their abandoning the 1st Tera of Exodus.         War was on the horizon. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>9 gods of Exodus 1. Yilos - sun god (Early Spring- a time to worship fearfully and plant fields/ Yilos is the high god) 2. Kata - spirit god (Late Spring- a time of pilgrimage to pray for good crops and other things) 3. Diea - twin moon goddess (below) Interchangable when speaking about Summer. 4. Miea - twin moon goddess (Early to Late Summer- a time of festivities to pay homage to the moon gods in order to appease their wrath; Blood Moon is the time of the Mordis Gal, the night of sacrifice because the gods are angry. Blood Moon can come at any time of the year and conflicts with the worship of other gods, especially Yilos, the high god. But he never seems to mind. The rule of Mordis Gal is to kill someone you love to show your loyalty to the moon gods to appease their wrath) 5. Fiross - fire god (Early Fall- A time to make ammends, fellowship and pray for a good harvest) 6. Ousil - water goddess (Late Fall- a time to pray to the god of water who sustains life) 7. Rawtis - Earth god (Harvest Season- A time to harvest crops and pray for yielding of much with festivities) 8. Mayu - wind goddess (End of the year- a time of foretelling; a season of heavy wind means the next year will be harsh, a season of mild wind means Mayu is content and won't argue with the other gods making the next year pleasent) 9. Tarris - traveling star god (No season- The feared god that contends with Yilos for dominion over Exodus. By day Yilos rules, by night, Tarris rules and is the god of the Elves. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Places </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>EDEN </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Haulvin </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Terrill </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Gavor </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Ardol </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Tarkon </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Dalar </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Soalmin </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>FREE LANDS </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Baksol </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Marshlands </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>White Desert </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Savale Forest </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>ELISE </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Calmone </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Overview </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>OVERVIEW Calmone is one of the oldest countries of Elise. It's history dates back farther than man can remember. However in recent centuries, Calmonians have discovered that their own history has vanished. When trying to find records of their ancestory, there is none to be found.         This has caused a stir of rebelion against the White Council, the most powerful Empire on Exodus whose influence is in every government entity. It is widely known that the White Council plays dirty but to go against them means dire consequences.         When digging up their past in secret, King Joshua discovers something far greater than his ancestry. It's about an Ancient Race whose tie to Calmone will bring about a revolution in history where Ancients and humans co-exist once again under the banner of Dragonborn. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>People and Religion </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>PEOPLE AND RELIGION The Religion of Calmone is much like that of all other countries who worship the 9 gods. Each province has a priority to one god over the others depending on what they need most. This is the breakdown of Calmone's provinces: South Valley - Temple to Yilos, Kata, Miea, Fiross, Ousil, Rawtis, and Mayu (South Valley is a major supplier of crops for Calmone so all the gods of farming are prayed to. Major temples are built together in cities as well as in the capitol) Sier Tav - Temple to Miea (Seir Tav is a mountain terrain where people must hunt for their food. They sacrifice their hunts to appease Miea and thank the god so the next hunt will be bountiful) North Valley - Temple to Tarris (North Valley is home to Calmone's advanced military training camp so they are always traveling. Tarris is a traveling god and though they risk angering the powerful Yilos who opposes Tarris, Tarris protects the traveler.) Reshland - Temple to Mayu (Reshland is a plainland and it's people have no need for most gods. The wind god offers a unique gift of foretelling. Most people living in Reshland are gypsies.) </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>A. Sarsda - In Order </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Monarch </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>King Joshua: </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Prime Minister </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t> Utis Hieser: Overview:  In the days of King Fester, Hieser was made prime minister of the High Council of Calmone. Hieser owns a portion of land inside the capital city of Sarsda. This land holds tenants and inns of an upper class. Personality: Friendly to a point but stands by himself in formal banquet settings and parties. He does not trus many people. Appearance: short crisp greying hair. He wears fancy clothes almost always. roundish face with a small mustach. He is kind of chubby and staunch. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Lord Marshall </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Saul Jennings: Overview: Jennings commands the royal guard consisting of all Black Knights. He </w:t></w:r><w:r><w:t>holds a mansion inside Sarsda. Personality: Jenson has a mild to flaring temper depending on the day. If his trainees are not fairing well, his temper gets rough. He does not tolerate failure very well. Appearance: Course semi-long dark brown hair that is usually tied back. His skin is rough, muscular and tanned. There are scars that litter his body and one that runs the length of his face close to his left eye. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Merchants </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Merchants There are numerous merchant guiles inside Sarsda, some even who sit on the High Council. Not born of noble blood, they have earned their place by their own contribution to Calmone by way of their Merchandise that brings wealth to Calmone.     These Houses are a very powerful influence in the Council because the country itself survives partly off of their sells and foreign exports.     Merchant House of Meccles Info: Meccles is a main trader for Calmone in the area of sculptures and art. Those of high classes from other countries highly prize the Meccles art and pay a high price. House of Sier-Tav Info: Sier-Tav is the other main trader for Calmone who trades the metals made in the highlands of Sier-Tav. Their craftmanship has been world renowned through the ages. Ambassadors come from across the Drysin Sea just to commission something to be made.     Though Sier-Tav is on the other side of Calmone, they have a guild within Sarsda and a regular transport of goods that ship weekly.     It has made few friends inside the Council. Sier-Tav is seen as a barbarian province far outside the reaches of Calmone's patrol.     Marquee of Sier-Tav: Lothin Stingar is lord of the province and a regular attendee and personal friend of King Joshua. Nobody messes with him for two reasons. 1. Personal friend of the King 2. Sier-Tav is known for their extreme hard way of life and constant border protectors. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>High Council </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>High Council Under Utis Hierser as prime minister, the High Council consists of elected deligates (taken from various parts of each province) to represent the major provinces, the treasurer, the Merchant Guiles, and the noble classes. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Bishops of the 9 </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Bishops of 9 The Bishops consists of the local bishops who have the temples of 9 inside Sarsda. They do not go outside of Sarsda much. Their main purpose is to stay inside their temples and pray and transcribe ancient text. Priests: The secondary order is to send out Priests to the land to heal the sick and use the magic of the 9 to heal the earth, bless the crops, etc.     They answer to the High Priest of Calmone alone. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Black Knights </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Black Knights Info: In Sarsda, the Black Knights are the Marshalls of Sarsda and it's surrounding city. Each BK holds his own small portion of land inside the capital, not more than one on the High Council but suitable for his own needs to be called lord. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>B. Southlands - In Order </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Overview </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Overview: The Southlands surrounds the capital of Sarsda on the Rock Lake. Sarsda does not answer to the count of Southland. It is it's own mini province within the walls of Sarsda.     Southland is primarily a farmland made up of fields and farms dotting the landscape. Grassy hills and valleys make up the majority of Southland.     The rock river borders the west end of Southland and is a major transport route within Calmone. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Count </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Count Malic Jervin: Overview: Jervin is a laid back man who is prone to bringing in festive activities to Southland. He likes entertainment and likes a good competition. With Sarsda so close by, he devised a plan to make his capital city the festive capital. Personality: Jervin has a soft heart for people and the soldiers under his command are well taken care of. The surrounding  cities closest to the governing city is well watched over because Jervin cannot stand seeing anyone going without aid. Appearance: Malic Jervin wears short cropped light brown, at times red hued hair. His face is a bit pudgy but his overall </w:t></w:r><w:r><w:t>frame is not too overweight. He keeps active outside of his castle going on hunts with his soldiers to keep up the spirits. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Viscounts </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Viscounts Info: Sherrifs underneath Count Jervin who patrols the cities and towns of the province. They have their own manors on site of the cities. Names of Sherrifs: Markus Lan (town:Hill Valley) Landon Corbin (town: South Hill) Maxus Kain (town: Mayfield) Kisinger Jara (City: Forge City) </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>C. Northlands - In Order </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Overview </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Count </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Count Derril Terrok Overview: Count Derril Terrok holds a large garrison of soldiers. In the common military of Calmone, Trusvill Garrison is the first stop after graduating from trainee.     Count Terrok sends out the fresh soldiers to patrol Northland's vast forests and largely unpopulated terrain to get them experienced in the field. Personality: Count Terrok is one of the toughest men in Calmone's military. His character is not for the courts. His temper is for the fields. His sole joy in life is to shout commands. However, he is extremely wise in his tactis so is kept on to train the soldiers. Appearance: Rough and browned skin. His eyes are like hawks. His hair is almost black with a hint of grey. He has a crooked nose and walks with a cane at times though more for show than anything else. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Dukes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Lord Kraes Formore Overview: Kraes Foremore is a nobleman related to House Cornith, a very old linage of science learned.     Foremore's father had fallen out of favor with King Fester for unknown reasons and was removed from the capital city to be made a Duke of Northland. This title is not popular among the nobles. There is nothing but forest and bandits in the Northlands. It is more a punishment Palace he was sent to live in.     Kraes Foremore grew up among the forest and made friends with the Border people. His ideals were not those of the capital. He still upheld the land however. If he did not, he would lose the litle bit he had in life. Personality: Bitter and vengeful, he has a very secretive nature. He holds to himself and has no serfs. There are only slaves on his land. Appearance: Foremore has a high brow and receeding hairline that is thin whisps of auburn streaked with grey.     He has a gated walk and a raspy voice that matches his evil eyes. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Viscounts </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Viscount: Info: There are no true sherrifs in Northland. The towns that are there are so far apart that they are watched by their own people. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Bishops </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Bishops: Priest Damus: Damus acts as the sole Bishop of Northland. The reaches of the White Council has not stretched into the province. He travels a circut route down the unkempt roads. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>D. Vilac - In Order </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Overview </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Duchess </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Duchess of Vil Lady Emlin - Overview: Lady Emlin is King Joshua's only sister and duchess of the royal vacation house of Vil. When finding a day to get away, Joshua takes the family to Vilac to visit his sister in Vil where she has everything ready. Lady Emlin is not simply the duchess of Vil but holds the border of Calmone and Percvam with an ample supply of soldiers at her command.     Ambassadors frequent the Palace Vil before going northward to Sarsda. This way, Lady Emlin can plant spies inside the ambassador suits to know if they hold secrets of harm against the country or King. Personality: Lady Emlin is first and foremost mischievious. She is loving but underneath her skin, she is always searching for trickery. Appearance: Lady Emlin has long blonde hair that she wears in many different styles. Her body is looked upon by all, men and women as touched by the gods.     Her skin is silk and her eyes sparkle green with laughter. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>E. Cabol - In Order </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Overview </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Count </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Count Simbar Rolis Overview: Rolis is a converted pirate who once roamed the Drysin Sea. Now he holds the title of governor granted by King Fester. Over the years, Simbar Rolis has managed to use his years as a pirate to his advantage gaining favor and allies where others could not.     Cabol quickly became one of Calmone's most important and wealthy provinces.     Rolis' skill in trade and the atmosphere he created for the major cities on the sea made port cities explode.     It was also one way to bypass all other countries that wanted to tax everyone for going through their land on trade business. Personality: Rolis had a friendly way about him with everyone. For his hefty size and background, at times people forgot he use to be a pirate. He was one with the people. Appearance: Simbar Rolis has a heavy set frame. His face is round and his blonde hair covers him splitting down the middle. He wears spectacles over a jolly happy face. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Viscounts </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Viscounts Info: Black Knights patrol the small peninsula province. Being Cabol is a province of much trade flowing directly to the capital, a series of heavy patrols constaly watch the roads and rivers. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>F. Borderlands - In Order </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Overview </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Overview Info: The Borderlands are a rough terrain on the eastern edge of Calmone with the Whiteface mountains making up a natural barrier. However, the mountains are home to many wild and dangerous creatures including wild savages relating to the Simrathes, a canibalistic tribe, that live north east of the Drysin Sea.     It is necessary to keep watch over these mountains. The things that come out of the mountains are not meant to live beside humans. They are more myth than factual to man unless you are unlucky enough to get called to be a Borderwatch at the Tower. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Marquee </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Marquee Victor Kliss Overview: Victor Kliss was appointed marquee of the borderlands in King Fester's reign. He was not a noble but a mercinary who knew his stuff well. At one point he had done a great service for King Fester. In return, King Fester asked Victor to name something he wanted and if it was in his power, Fester would give it to him.     Victor's heart was truly genuine and humble. He knew of the troubles the King had in some of his soldiers. Victor told the King to name him the Marquee of the Borderlands and in return he would turn the King's stubborn highborn trouble makers into true soldiers.     The King agreed quick enough and Victor Kliss was named the Marquee of Borderlands with the Towers as the destination of any soldier who the King decreed trouble for his kingdom. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Borderwatch </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Borderwatch Info: These are common soldiers all the way to high born generals who are expelled from Calmone's military. Under the watch of The Towers, they patrol the Borderlands of Calmone. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>G. Reshlands - In Order </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>H. Keshland - In Order </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>I. Sier-Tav - In Order </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Percvam </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Overview </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>People and Religion </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>A. Baeler - Capital </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>B. Kae Dias </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>C. Skeer </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Rumeran/White Council </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Overview </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Structure of Government </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Dunland </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Overview </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Dacmer </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Overview </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Silas </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Overview </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Dragon's Realm - Midlands </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The Midlands </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History of Midlands The history of the land is extensive, steeped in war and wonder </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>1. The Immortal Forest </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>2. The Great Wall </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Province of Trenstone </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Giant's Entrance The history of the Entrance </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>1. Bridge of the Heavens </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The Story The Bridge of Heaven was built when the realm itself was built. It is so wide in length that towns recide on the massive land bridge. Large pillars and tunnels hollow out the underneath to allow the valley below to breath and it's lakes and rivers to flow naturally.         When first exiting the massive Giant Entrance into Dragonborn's Realm, you are immediately greeted with the pillars of Heaven City.          This is where any newcomer will be given the tools necessary to get around the rest of the realm. Maps are given out. Words of wisdom and direction of each province and their duke's holdings is clearly shown.         The rest of the adventure is up to the individual. If you are an ambassador, the King's Royal Knights will escort you to the entrance of the palace (a week's travel away).          Heaven City is also a Border City with a Marquee. The city is heavily guarded and ready for war being it borders the only entrance into the realm of Dragonborn. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>2. Stoneledge Forest </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Special Attributes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>3. Terra Pass </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Special Attributes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>4. Greylin-Kul City </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Special Attributes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Province of Terravil </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Province of Terrival History of Terrival </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>1. Terravil Forest </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Special Attributes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>2. Stone of Tears </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Special Attributes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>3. Keeper of the Unborn </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Special Attributes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>4. River of Dreams </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Special Attributes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>5. Wall of Birth </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Special Attributes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>6. Path of Tests </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Special Attributes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Province of Terrasil </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>7. Dragonsphere / Gate </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Special Attributes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>8. Furies Forest </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Special Attributes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Province of Trievin </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Province of Tri-Stone The history of Tri-Stone </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>1. Temple of Gaul </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Special Attributes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>2. High Temple of Seers </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Special Attributes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>3. Land of Faye </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The History </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>The People </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Special Attributes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Province of Starlin' </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Province of Uerth </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Province of Tolsin </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Verlone </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Overview </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>OVERVIEW Calmone is one of the oldest countries of Elise. It's history dates back farther than man can remember. However in recent centuries, Calmonians have discovered that their own history has vanished. When trying to find records of their ancestory, there is none to be found.         This has caused a stir of rebelion against the White Council, the most powerful Empire on Exodus whose influence is in every government entity. It is widely known that the White Council plays dirty but to go </w:t></w:r><w:r><w:t>against them means dire consequences.         When digging up their past in secret, King Joshua discovers something far greater than his ancestry. It's about an Ancient Race whose tie to Calmone will bring about a revolution in history where Ancients and humans co-exist once again under the banner of Dragonborn. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>People and Religion </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>PEOPLE AND RELIGION The Religion of Calmone is much like that of all other countries who worship the 9 gods. Each province has a priority to one god over the others depending on what they need most. This is the breakdown of Calmone's provinces: South Valley - Temple to Yilos, Kata, Miea, Fiross, Ousil, Rawtis, and Mayu (South Valley is a major supplier of crops for Calmone so all the gods of farming are prayed to. Major temples are built together in cities as well as in the capitol) Sier Tav - Temple to Miea (Seir Tav is a mountain terrain where people must hunt for their food. They sacrifice their hunts to appease Miea and thank the god so the next hunt will be bountiful) North Valley - Temple to Tarris (North Valley is home to Calmone's advanced military training camp so they are always traveling. Tarris is a traveling god and though they risk angering the powerful Yilos who opposes Tarris, Tarris protects the traveler.) Reshland - Temple to Mayu (Reshland is a plainland and it's people have no need for most gods. The wind god offers a unique gift of foretelling. Most people living in Reshland are gypsies.) </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Structure of Government </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Structure of Government Calmone's King has the final say but deligates power to those below him. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>A. Sarsda - In Order </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Monarch </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>King Joshua: </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Prime Minister </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t> Utis Hieser: Overview:  In the days of King Fester, Hieser was made prime minister of the High Council of Calmone. Hieser owns a portion of land inside the capital city of Sarsda. This land holds tenants and inns of an upper class. Personality: Friendly to a point but stands by himself in formal banquet settings and parties. He does not trus many people. Appearance: short crisp greying hair. He wears fancy clothes almost always. roundish face with a small mustach. He is kind of chubby and staunch. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Lord Marshall </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Saul Jennings: Overview: Jennings commands the royal guard consisting of all Black Knights. He holds a mansion inside Sarsda. Personality: Jenson has a mild to flaring temper depending on the day. If his trainees are not fairing well, his temper gets rough. He does not tolerate failure very well. Appearance: Course semi-long dark brown hair that is usually tied back. His skin is rough, muscular and tanned. There are scars that litter his body and one that runs the length of his face close to his left eye. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Merchants </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Merchants There are numerous merchant guiles inside Sarsda, some even who sit on the High Council. Not born of noble blood, they have earned their place by their own contribution to Calmone by way of their Merchandise that brings wealth to Calmone.     These Houses are a very powerful influence in the Council because the country itself survives partly off of their sells and foreign exports.     Merchant House of Meccles Info: Meccles is a main trader for Calmone in the area of sculptures and art. Those of high classes from other countries highly prize the Meccles art and pay a high price. House of Sier-Tav Info: Sier-Tav is the other main trader for Calmone who trades the metals made in the highlands of Sier-Tav. Their craftmanship has been world renowned through the ages. Ambassadors come from across the Drysin Sea just to commission something to be made.     Though Sier-Tav is on the other side of Calmone, they have a guild within Sarsda and a regular transport of goods that ship weekly.     It has made few friends inside the Council. Sier-Tav is seen as a barbarian province far outside the reaches of Calmone's patrol.     Marquee of Sier-Tav: Lothin Stingar is lord of the province and a </w:t></w:r><w:r><w:t>regular attendee and personal friend of King Joshua. Nobody messes with him for two reasons. 1. Personal friend of the King 2. Sier-Tav is known for their extreme hard way of life and constant border protectors. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>High Council </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>High Council Under Utis Hierser as prime minister, the High Council consists of elected deligates (taken from various parts of each province) to represent the major provinces, the treasurer, the Merchant Guiles, and the noble classes. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Bishops of the 9 </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Bishops of 9 The Bishops consists of the local bishops who have the temples of 9 inside Sarsda. They do not go outside of Sarsda much. Their main purpose is to stay inside their temples and pray and transcribe ancient text. Priests: The secondary order is to send out Priests to the land to heal the sick and use the magic of the 9 to heal the earth, bless the crops, etc.     They answer to the High Priest of Calmone alone. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Black Knights </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Black Knights Info: In Sarsda, the Black Knights are the Marshalls of Sarsda and it's surrounding city. Each BK holds his own small portion of land inside the capital, not more than one on the High Council but suitable for his own needs to be called lord. </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Territories of Elise </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Tribal Lands </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Wilderlands </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Simrathe </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>LEGEND ISLAND </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>SCARON </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t> The World of Magic </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>White Magic </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>The System </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>White Council </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Pentarch Wizards </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>White Mages </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>War Mages </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Bishops </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Council Mages </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Temple Knights </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>Wild Magic </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>The System </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Relic Artifacts </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Blue Star Whip </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Elemental Rings </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Staff of Twilight </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Wild Mages </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Seekers </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Dragonblood </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Ancients </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Main Characters </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Dragon Tribes </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Fairies </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Unicorns </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Dryads </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Nymphs </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Other Characters </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P21"/></w:pPr><w:r><w:t>Places of Magic </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Ancient Seats </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Fae Realm </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Crossroads </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Temples </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>The Tera Veil </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P23"/></w:pPr><w:r><w:t>Autumn Realm </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Twilight Forest </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Temple of Taumil </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Temple of Adrylin </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P22"/></w:pPr><w:r><w:t>Dragon Chamber of Legacy </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Religion </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Legends </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Resources </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Currencies </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Languages </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Races </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Cultures </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P20"/></w:pPr><w:r><w:t>Special Events </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P19"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P11"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P3"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image1"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image1" o:title="Image1"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P7"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>In the sacred library of Tearvane, the records of Extal Worlds remain untouched, bound by magic and preserved for all time. But on Exodus, the White Council’s hold on the human races is strong. Their version of history is even stronger, directing humanity how they see fit.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P2"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image2"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image2" o:title="Image2"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P7"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P1"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>At the end of the last age, human ingenuity had advanced to the point that science, through the manipulation of DNA, could create life however they deemed fit. This was called genetic transitioning, the future of the human species. Parading themselves for being so advanced, pride in godhood forsook common sense. At first, the sciences treated medical needs, almost eliminating all ailments and diseases with DNA infusion of synthetic parts created. But this was not enough. The ability to create life was too </w:t></w:r><w:r><w:t>enticing for some.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Bio-engineered superhumans was the proper term used. Sensible people called the weaponized science for what it was – monsters. From failed experiments to increasing understanding, freaks of nature were born out of labs.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>But in secret labs of the elite who had controlled the world governments for centuries, their experiments were much more sinister. Steeped in religious rituals to the gods, they created hybrid creatures, bred for a single purpose. They were to house the spirits who roamed the Earth, seeking bodies to reinhabit from once they had lost ages ago. These were the demons of biblical lore. Their masters, higher spirits who ruled the nations, whispered in the ears of their followers. What transpired was a wealth of knowledge to create and bare physical beings once called Nephilim.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Once born, the avatar body would be placed on an altar for the blood rituals to commence as degreed, mimicking the rituals of ancient Babylon. With fertility rituals performed by the temple virgins, the prayers to Beezelbul lifted to heaven.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>And with the ceremony of opening the mouth, the cryptid avatar breathed life of a demon spirit.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>What followed was a reign of unimaginable horror done to humans and animals alike. Humans had unleashed hell on Earth.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Wars broke out as chaos reigned. Like their ancestors of old, the blood lust of cryptid monsters was unsated and terrorized the world.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>With their cryptid hosts, the ancients went to the known tombs of their brothers and brought out the bodies of the giant remains. And through the process of DNA and transitioning, they recreated their former bodies, to roam again as giants, to ravage the lands and terrorize humans.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The world grew dark in the bloodshed of nightmare creatures.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>For those who knew the power behind the nightmares drew together in force, forming the House of Sherwin, led by a Lord of unknown power at his command. His own legacy was shrouded in mystery but his feats against the monsterous beings made him a </w:t></w:r><w:r><w:t>legend.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>All this ended as the world leaders, never arriving at any agreement, maddened with fear, made war on each other. The world burned red with blood.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P5"/></w:pPr><w:r><w:t>----------------------------------------------------------------------------------------------------------------------------------------------------------------------</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image3"/><v:shape id="_x0_0_0_0" style="position:absolute;z-index:0;left:0pt;top:0pt;width:0pt;"><v:imagedata src="wordml://Image3" o:title="Image3"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The Elemental Age is broken up into two categories: The era of House Lords and The era of Universal Powers.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The era of House Lords came about as the world’s entire economy collapsed as well as stable governments. Within the United States, more than any other country, this broke up the unified federal lands to become city-states and regional territories, governed by local houses. The Federal Government was dead and not wanted to be resurrected. Those in power had started the war in deliberate opposition to the people. Nobody forgot this and as industries began to populate the lands once more, uniting under any federal system was seen as bad. The constitution, once holding the states together, was gone. Trust in any federal government was looked on as a curse.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Beginning at a local town level, mayors were still elected but without the power it once had. This quickly became a problem as resources for towns struggled to survive under such strict ruling. People remembered the things they once had under a unified system of shared resources. When the promise of wealth was given by the few larger landowners who held more wealth in crops and farmlands, people flocked under said banner.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Soon, what were only small portions of land began building under house names. These became known as city-states. And as industries boomed again under the strange new crystal energy, the city-states competed for dominance and small feudal wars broke out. In essence, they were tribal wars fighting over land resources and its people.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Over the years, the house names grew in power and dominance to become powerful </w:t></w:r><w:r><w:t>lords with committees that governed their vast lands conquered and the people within.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The regions under the control of house lords were dictated only by the number of people and commodities sold. For instance, the land called Michigan, was governed by two house lords while the lands north of the Mackinac straights were uninhabited. It was said within those lands roamed the beasts that took the people decades to drive out of the southern peninsula. The creatures were never before seen monsters that appeared at the time of the crystal shards.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>With the use of airships, trains and inventions of crystal-powered mechanics, the Elemental Age brought with it a dark, destructive force man wanted to harness and control the masses with.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>300 years after the introduction of Sinvin (The crystal shards), Earth is vibrant with technology once more, living off the energy of Sinvin. Its power is in everything that has been invented.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>However, there are those in society who know the truth. Sinvin is not to be trusted. Its very essence is a tainted shard of what is called the Balance Crystal found in the fae world of Gontha. Shortly before the fall of Dragonblood, the guardians of humans and fae, one of two crystals that balanced the magicborn world shattered. The forces of a dark emperor took the shards for themselves and disappeared. It wasn’t known what had taken place afterward, but the world of Gontha became unstable.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The few who know this story, see the effect the tainted shards have on Earth’s societies and know it for what it is.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The crystal shards spread poison throughout the lands. Voices of a realm far beyond speak into the minds of men giving new ideas, depraved and wicked.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The Universal Powers are similar to the house lords that govern the lands of Earth. But they are fewer. These are the true rulers of the world, housed in human form, they are lords of great strength. Their words are law and they are the gods of men as human societies slowly find themselves enslaved to the powers.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P2"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image4"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image4" o:title="Image4"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P2"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image5"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image5" o:title="Image5"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P10"/></w:pPr><w:r><w:t>- E X O D U S -</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P12"/></w:pPr><w:r><w:t>~ The Books of Record~</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P6"/></w:pPr><w:r><w:t>VOL 1 – BOOK OF TIME</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The vast worlds of Extal (the fae realm), are governed by the Sacred Books of Record. What transpires within each world realm ultimately reflect onto Earth in dreams and imagination. They are such powerful books that no man has glimpsed a single Sacred Book. They are held and guarded by some of the most powerful Ancients. Only one book is known to be kept by the ancient Dragon Tribes of Exodus.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The first volume, “The Books of Time”, is said to hold all of history’s recorded events in a single, general overview. It’s also an overview of the other three books of record. Within the pages are laws of cosmic and natural nature. Held by the Keeper of Records, he writes what is told and ensures things stays true to the book.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P6"/></w:pPr><w:r><w:t>VOL 2 – BOOK OF WORDS OF POWER</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Words of Power are specific weaving of fae words never meant for human understanding. This forbidden language is the language of Extal and the fairy race who from the beginning of time, helped cultivate and sustain life. In the wrong hands, the weaving of song and letters could cause dark curses or worse, the unweaving of the fae worlds.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>In the Book, “Words of Power”, is written the laws and coding of the words and usages balance out the fae worlds. A tweak here and there can change weather patterns, give strength to blooming plants and stabilize a world’s ecosystem. The book is guarded heavily within the Twilight Forest, where no human is allowed to venture. Within these forests, magic thrives the greatest as it’s connected with the Balance Crystals that sustain life in the central world, Gontha, or as humans call it, Exodus.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P6"/></w:pPr><w:r><w:t>VOL 3 – BOOK OF BALANCE CRYSTALS</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Since the dawn of Gontha, when the Creator God sang life into existence, there was also sung two magical crystals that connected the central world of the fae to the rest of the fae realms. It was the heartbeat of magical creatures that balanced the fae worlds.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Housed in temple structures, each on opposite ends of Gontha, the fae songs flowed in unison with the twin heartbeats, forming a continuous flow of energy to and from each realm in existence. From Earth’s Celtic lore, this was known as the endless knot.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>In the Book of Crystals are written the inner workings of the crystals. With it are written </w:t></w:r><w:r><w:t>the cosmic rules that govern each crystal and its functions. As with other books, no mortal has the ability to gain access to them and cannot change the writing.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>However, if one is found by those with dark intent, there are safeguards put into place but not many. The books were written before humans inhabited the lands of Gontha so there was no need for such things.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P6"/></w:pPr><w:r><w:t>VOL 4 – BOOK OF THE DRAGON PROPHECY</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The Fourth and final book is called, “The Dragon’s Prophecy,” a long and almost forgotten tale. Although the book is considered part of the Book of Records, it is not completely inaccessible.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>When Dragonblood came into existence and began building its own realm with the aid of dragons, it was time to enact a guardian at the crossroads to guard its passages.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>To the twin brothers, Shrukin and Darius, devout members of Dragonblood’s council, fell the task of guarding the way. One would make his home in the fae mists itself where a safe haven would be placed for him. This way, being human, he would not get lost in the fae mists and wander aimlessly forever.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>To the other, the task of Records Keeper, was given. His job was to record the events of history, to safeguard against human contamination of greed and corruption. At the same time, a vision was given to begin writing down a specific set of verses. These were to be distributed among Dragonblood’s people to memorize and keep to their hearts. This would become their creed, their legacy.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>As each age of human history begins, a new chapter is written into the Dragon’s Prophecy, to encourage but also to warn man of the heart’s easy sway into the darker things.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>As the fourth age dawned, a new chapter was written. But in these chapters were written dark and ominous warnings throughout. It’s contents would be read high in the mountain passes of Dragonblood as they fled their homeland.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Darkness has fallen…</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P18"/></w:pPr><w:r><w:t> </w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P16"/></w:pPr><w:r><w:t>E X O D U S</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P16"/></w:pPr><w:r><w:t>B O O K S</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P2"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image6"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image6" o:title="Image6"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P2"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image7"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image7" o:title="Image7"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P10"/></w:pPr><w:r><w:t>~ M A G I C ~</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P15"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Throughout the 5 human kingdoms of Elise, White Magic is the one true magic that is accepted as good. With the Order of the White Council governing all things magic, it is held with high esteem. The White Priests and all who are under the White Council of Wizard’s order are also revered. It could be said that anyone under the banner of the White Council is held greater than even Kings and Queens.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>According to the White Council, white magic is a good source of magic flowing directly from the gods down to those deemed blessed by the White Council’s priests. This is the only magic seen as good. All other sources are evil and must be eradicated as it’s not blessed by the gods and is seen as poisonous and a direct attack on the gods’ order of things.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The White Council is an order of wizards that has been around since the 1st Age of humans on Exodus. Their history is forgotten by most but for those who know where to look or those with long memories.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The order of the White Council is split into 6 categories.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>This is the ruling class of wizards, the highest order that can be achieved. They are considered touched by the gods and who’s words are law. They are a sect unto themselves and rarely interact with the rest of human society. Their office is to impart the will of the gods to the rest of humanity.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>These can be considered as mages of healing, and protectors of the crowns (most seen as elite warriors who are sworn protectors of bishops. Their focus is on nature and the divine.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>These are elite warriors who’s brute force is divinely powered. Their studies of the intricate spells handed down by the gods give them superhuman power. They are the force behind all of the White Council’s decisions among the human nations. They invoke fear and the wrath of the gods.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>These are the priests of the nine high gods of Exodus. Each human kingdom is given a high bishop to shepherd its people in the duty of serving their sworn god. Their power comes in the form of divination, blessing and curses. To insight the wrath of a high bishop can spell a lifetime of misery. To please the high bishop could easily see a lifetime of wealth. Normally, this doesn’t happen but they are second to the Pentarch Wizards in knowing the will of the gods.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>These are the advisors to the crown. They come in various skills as both white mages and war mages, and sometimes a mixed bag. Their skill lies in strategy and understanding the workings of the White Council’s human affairs. It is never good to anger the White Council or the gods. Since they commune with the gods, their power ins vast and no human king will ever cross the will of the temple priests. The Advisors may even use special magic to influence decisions however they see fit.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Some Kings over the centuries have gotten angry that their advisors hold so much power, sometimes more than themselves. But this is rare or it is never spoken of in public as this would incite the White Council to look closer into a King’s affairs.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>These are very specific warriors. They protect the temples across the human kingdoms and are solely controlled by the White Council. No other person has the right to enforce anything of them.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P16"/></w:pPr><w:r><w:t>Wizards of the</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P16"/></w:pPr><w:r><w:t>White Order</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P2"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image8"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image8" o:title="Image8"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P15"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Wild Magic has a long history for those who know where to look. With most things on Exodus, the hidden past is steeped in old magic and relics attesting to this. It is said that </w:t></w:r><w:r><w:t>Wild Magic is forbidden for a very secretive reason. Those who have tried to harness it never could except a very specific race, Dragonblood. And as history recalls, Dragonblood were the White Council’s nemesis.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>In hidden diaries and old forgotten books that missed the White Council’s burning, the true power of wild magic is revealed.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>On the eastern edge of the continent Elise, where human kingdoms reside, the Volesin Sea separates it from the sister continent of Eden. It is here where wild magic still thrives. And with it, creatures born of the fae. It is the magic of Exodus that magicborn creatures live and breath. It is essential to the entire world, a fact that is deliberately hidden from human societies.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>From long forgotten pasts, relics show up now and again that give evidence humans once indeed harness the wild magic though not in the way the White Mages do. Instead of holding it inside one’s self, artifacts are the containers to which the magic is used.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P13"/></w:pPr><w:r><w:t>MAGES + ARTIFACTS</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>In the human realm, there are two known classes of wild mages. The first are simply known as seekers.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Seekers are a group of secretive people who hunt for wild artifacts. They stay hidden from society for the most part in fear of word reaching the White Council of their whereabouts. They are seen as illegal citizens who if found, are to be killed on the spot. Rewards are offered for their heads.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Seekers usually have one or two artifacts on hand and use them for the good of the people. They hold to a strict code of conduct while using their found artifacts for the good of the people.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>They live in small nomadic tribes, roaming the lands and never staying to one spot for long. They have a death sentence on their heads at all time so keep to the free territories not governed by the kingdoms.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Dragonblood have books upon books written about them. Even though the White </w:t></w:r><w:r><w:t>Council tried to destroy every last vestige of the name, some still remain in hiding.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Dragonblood, shortly after their appearance in history, became legendary emissaries between the magicborn and human alike. They were the peace keepers, guardians of renown as they were granted special privileges by the high lords of Exodus, the dragon tribes. High in the mountains of the Midlands, they were given the task to uphold the laws of the Creator God while stemming the tide of evil brought on by a dark emperor’s need to become a god.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Through nightmarish experiments of dark alchemy, Dragonblood was birthed, no care given to those who went insane, others struggling to remain normal. Through it all, Dragonblood was a special kind of human hybrid race. They had an innate ability genetically encoded to the DNA and future DNA to somehow harness the elements of the world. And with enhanced gifts from dragons, breathed on by their flames of magic, they used their power mostly for good.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P16"/></w:pPr><w:r><w:t>Ancients of</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P16"/></w:pPr><w:r><w:t>Wild Magic</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P2"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image9"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image9" o:title="Image9"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P15"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>It is said that every Dragonblood King was given a special gift at their coronation by a dragon high lord. These were to aid them in their long battle to stem the tide of evil hearts that never stopped corrupting.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The Dragon Star Whip is a whip that has been dipped into dragon’s fire and will never go out. Its properties are very destructive but most deadly against dark magical forces. The tip, made out of shards of dragon scales and blood, is one of the most powerful artifacts gifted to mankind.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The Elemental Ring is a ring embued with magic that calls to the elements by the user. Gifted by the Queen Elrosa of the Twilight Forest, this fairy ring can rival the Dragon Star Whip in its power.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>This staff is rarely seen as its might lies in its ability to call on the most powerful magic, </w:t></w:r><w:r><w:t>the balance crystals, to do ultimate damage or healing, depending on the need. It is second only to the Sword of Eskaver.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>This sword can only be wielded by one of royal blood and even then, only one worthy of it. The power within the sword is a combination of both dragon and crystal. It’s power lies with the ability to control magical elements as well as magicborn alike. It is not a weapon that is used lightly and more often than not is seen in the Sword Hall of Dragonblood’s Palace. Only in dire need is it to be lifted and used. Its properties have the power to destroy armies with a single thrust. Thus, in events of those who are unworthy, it cannot be touched without searing, unbearable pain.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P16"/></w:pPr><w:r><w:t>Magical Relics</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P7"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P2"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image10"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image10" o:title="Image10"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P2"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image11"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image11" o:title="Image11"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P16"/></w:pPr><w:r><w:t>~ BALANCE CRYSTALS ~</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P14"/></w:pPr><w:r><w:t>BALANCE CRYSTALS OVERVIEW</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>When the Creator God formed the fae realms and the creatures within, He also formed twin Crystals of Balance.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Within each crystal, holds the magical properties of a dragon star, fueling Exodus and all other fae worlds it’s connected to. In the unlikely event that one of the twin Crystals are shattered, signs throughout nature will be apparent. The task falls to the High Lords to fashion the crystal shards into usable items before hiding them. A time will come when the items will be most needed and taken up to defend the fae against the darkness.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Along with the twin Balance Crystals, there are numerous smaller crystals that act as conduits of the Balance Crystals.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>It is no secret that the place names of each crystal are known. They were known from the beginning. But to find the temples themselves is shrouded in mystery.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>From age to age, many have paid good money to the most skilled hunters and artifact finders. But the truth is hidden.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Tausa’s Crystal is one of the two main Balance Crystals of Exodus. It’s housed within a secret temple off the coast Elise on one of the many islands. At one time, it was guarded </w:t></w:r><w:r><w:t>by sacred knights who swore allegiance to its protection. But that is part of history and the fall of Dragonblood.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Within the temple structure, the massive crystal sits center of the great room while at its base, seven swords of power lay. Each sword was made in the 2nd Age by forging smller crystals bound to the Balance Crystals. These were made by Dragonblood as weapons to fend off the darkness of Scaron’s emperor.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>At the end of the 3rd Age, Tausa fell and the Crystal shattered by dark means. This story is told in the History of Ages.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Very little is known about this Crystal except what has been recorded in the early parts of the 4th Age. Housed within a temple at the center of a large lake, it is the last defense of Exodus and the fae. Since the shattering of Tausa’s crystal, the world has become unbalanced. If Adrylin falls, the worlds of the fae plunge into endless darkness.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Some time in the early years of the 4th Age, Neverworld (the place of the Emperor of Night) sent into Exodus a force to capture and destroy Adrylin’s crystal. The events are told in the retelling of Ardil, a boy who became famous for his role in warning Dragonblood of impending doom. His story is known by many of the agicborn, not only for his heroism, but because he broke the laws of elven kind, falling in love with Verlone’s elven princess. That story is told elsewhere.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Today, Adrylin’s Temple is hidden again but without the guards it once had in the past. The world has grown cold and Dragonblood is no more. The dragons are beside themselves with anger.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The future is uncertain for all.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P2"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image12"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image12" o:title="Image12"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P2"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image13"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image13" o:title="Image13"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P10"/></w:pPr><w:r><w:t>~ T H E  G O D S ~</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P15"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Few, if any humans, now remember the ancient days. This was the age of exploration and conquest of foreign exotic lands. Discovered quite by accident, a secret society of man indulged in the exploration of a discovered land through an ancient crossroads.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>James Faelivrin, an ambitious man of science, saw how Earth was fast approaching a devastating, world-changing event. With the discovery of an ancient fae crossroads in </w:t></w:r><w:r><w:t>the middle of Michigan’s dense forests, he pulled his resources together and formed a team to go exploring.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>What he didn’t know was that he had was being watched carefully by ancient eyes who whispered in his ears, guiding him along a set path. And with said guidance, once in the world of Gontha, the whispers increased fervently, enticing his human nature to go beyond normal means to become an instrument of the gods.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The Gods of Exodus are similar to those of Earth. In any sense of the word, “god” means a “spirit” that lives in the spirit world, occasionally crossing into the physical to interact.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>On Exodus, formerly known as Gontha, the veil between the physical and spiritual is very thin. In fact, before humans exisited, the world was full of spirits that tended the magical properties that flowed in an endless cycle as the heartbeat of Extal, the system of worlds within the Fae.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Spirits come in many different forms, taking on the appearance of whatever pleases them to get a task done. However, their original form will always remain dominant in the physical sphere. For instance, a dragon who is lord of mountains and seas, can transform at will to another form. But this is only temporary as the dominant form always wins out.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>A fairy who’s task was to be caretakers of the plants and trees, would sing to the elements of the lands, bidding it to do the will given. Never did a fairy or dragon or any number of creatures born of magic forgot their place. And from time to time, would leave their place of residence to traverse to the heavenly places to give accounts of their activities and join in the celebration of life.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The introduction of man, specifically James Faelivrin, interrupted the dynamics of order. For in him, a dark, malevolent god followed with many of the same intentions.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Knowing their place in the Earthen realm was taken, the gods never forgot how it felt to be rulers over human slaves. Their madness of how Elyon, Lord of the Gods, made a world all for humans, and to place them amongst the gods as co-equal, stirred up wrath and blackening of hearts. Inciting themselves to break the boundaries of Heaven and Earth, they formed themselves human bodies and took for themselves women to rape </w:t></w:r><w:r><w:t>and bare children of a hybrid nature. In this, they would create for themselves their own race.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>But Elyon, in fury over what was taught and the manner of their children, brought down his wrath on the gods. For they instilled in man’s heart, evil continually. The children of the gods were brutal savages who tortured, raped, killed and ate human flesh. Their nature was pure chaos. The world of man had become a place of evil hearts.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Elyon brought down his judgement on all He had created. For those who had done the evil deeds, their spirits were inprisoned in Hades, to be chained in gloomy darkness till the end of time.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>But those were the memories of the past. The spirits were given dominion after humans again rebelled, to become rulers over nations. But like their predecessors, their roles were too great not to take into their own hands and steer humanity to worship themselves in place of Elyon.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Then came the birth, that great and horrible day. It would signal the end of their reign over humanity with legitimate power. They had tortured and incited their own form of cruelty on humans they saw as no more than slaves. The gods hearts were continually wanting for man to suffer.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>When Elyon’s son died, it should have been a cosmic celebration. But in reality, it was a devestating blow, their own legitimate status as cosmic rulers of human society, was stripped away forever.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>In fear and hatred, the gods drew back and for a time, waited, whispering their dark deeds to unknowing puppets.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>With whispers of greatness and immortal power, the gods used James Faelivrin as their new puppet. Here, they could once again do what was taken from them. But now, even greater things would be accomplished. On Exodus, their power would mingle with humanity to create another race, more powerful and devastating.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>When the Ancients of Exodus saw the workings of Faelivrin’s dark inventions and the evil being drawn into the world, they cowered. They had never known such evil to exist and </w:t></w:r><w:r><w:t>watched in horror as it poisoned the world and themselves.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Ancients and man were enslaved and with the whisper of the gods, a new race was born by wicked means.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>In the aftermath of such births, destruction followed and a darkness fell over all the world.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>In time, the manner of man’s hearts had even poisoned many of the Ancients of Exodus. In their own hearts, they became bitter towards man’s greedy nature for power. And as centuries passed and wars consumed the world with blood and death, the Ancients cried out for revenge, breaking their own boundaries.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>And once again, what was done at the beginning of humanity, came to be.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The gods would rule over man with anger and find in themselves, a need to be worshipped over their own Creator.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Taking the form of humans and beasts, they made humans to build temples to themselves, giving power to some in order to rule. In their power though, humans enslaved themselves to the gods as mages and wizards.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Thus, Exodus became a world of human mages, building the White Council to oversee all of human deeds, and in the process, erasing all history.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Elyon would never be allowed to interfere with the gods’ human slaves again.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P2"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image14"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image14" o:title="Image14"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P2"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image15"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image15" o:title="Image15"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P8"/><w:listPr><w:ilvl w:val="0"/><w:ilfo w:val="2"/></w:listPr></w:pPr><w:hlink w:dest="https://andrewnusz.com/dragonblood-encyclopedia/" w:bookmark="evil_eye" w:target="_blank"><w:r><w:rPr><w:rStyle w:val="Hyperlink"/></w:rPr></w:r></w:hlink></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P17"/></w:pPr><w:r><w:t>- BOOKS -</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P7"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="wP15"/></w:pPr><w:hlink w:dest="https://www.andrewnusz.com/ansville" w:target="_blank"><w:r><w:rPr><w:rStyle w:val="Hyperlink"/></w:rPr></w:r></w:hlink></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P7"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="wP15"/></w:pPr><w:hlink w:dest="https://andrewnusz.com/secrets-of-enali/" w:target="_blank"><w:r><w:rPr><w:rStyle w:val="Hyperlink"/></w:rPr></w:r></w:hlink></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P7"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut elit tellus, luctus nec ullamcorper mattis, pulvinar dapibus leo.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P2"/></w:pPr><w:r><w:pict><w:binData w:name="wordml://Image16"/><v:shape id="_x0_0_0_0" style="z-index:0;left:0pt;top:0pt;width:0pt;mso-position-horizontal-relative:char;mso-position-vertical-relative:line;"><v:imagedata src="wordml://Image16" o:title="Image16"/></v:shape></w:pict></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P10"/></w:pPr><w:r><w:t>The Evil Eye</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The exact origins of the creature dubbed, “the evil eye,” is a mystery. Some say it came from the far edge of the Extal Realm where the Emperor of Night was banished to in ages past. Others say it isn’t part of the Nightbreed, hybrid creations of Neverworld, but wholly other. There is some speculations that these are remnants of the original cryptids, those that were written of in history of man.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P9"/></w:pPr></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P4"/></w:pPr><w:r><w:t>The few records that have survived to make it into the Dragonblood Journals say that the creature glows with a pulsating eye shrouded in a cloud of lightning. Wings spread out from the clouds as it utters a deafening screech. It’s touch is death before it vanishes as though it is actually a ghostly image.</w:t></w:r></w:p><w:p xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0"><w:pPr><w:pStyle w:val="P11"/></w:pPr></w:p><w:sectPr><w:type w:val="next-page"/><w:pgSz xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0" w:w="12241.5302" w:h="15841.9803" w:orient="portrait"/><w:pgMar xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0" w:top="1133.9978" w:bottom="1133.9978" w:left="1133.9978" w:gutter="0" w:right="1133.9978"/><w:pgBorders xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0" w:offset-from="text"/><w:cols xmlns:fo="urn:oasis:names:tc:opendocument:xmlns:xsl-fo-compatible:1.0" w:num="1" w:space="0" w:equalWidth="on"/></w:sectPr></w:body>
        </w:wordDocument>